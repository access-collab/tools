@prefix :      <https://w3id.org/orda#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml:   <http://www.w3.org/XML/1998/namespace> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix prov:  <http://www.w3.org/ns/prov#> .
@prefix time:  <http://www.w3.org/2006/time#> .
@prefix odrl:  <http://www.w3.org/ns/odrl/2/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@base <https://w3id.org/orda#> .

<https://w3id.org/orda> rdf:type owl:Ontology ;
    owl:imports <http://xmlns.com/foaf/0.1/> ;
    dcterms:description "Models the data access process under the delegated act on data access (DA) and Art. 40(4) DSA, including application drafting, authorisation, and data access phases."@en ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:title "ORDA — Ontology for Research Data Access"@en .


#################################################################
#    Annotation Properties
#################################################################

###  http://purl.org/dc/terms/description
dcterms:description rdf:type owl:AnnotationProperty .

###  http://purl.org/dc/terms/license
dcterms:license rdf:type owl:AnnotationProperty .

###  http://purl.org/dc/terms/title
dcterms:title rdf:type owl:AnnotationProperty .

###  https://w3id.org/orda#hasLegalBasis
:hasLegalBasis rdf:type owl:AnnotationProperty ;
    rdfs:comment "Cites the legal provision governing this class or property, e.g. Art. 40(4) DSA."@en ;
    rdfs:label "has legal basis"@en .


#################################################################
#    Object Properties
#################################################################

###  http://www.w3.org/2006/time#after
time:after rdf:type owl:ObjectProperty .

###  http://www.w3.org/2006/time#hasBeginning
time:hasBeginning rdf:type owl:ObjectProperty ;
    rdfs:domain time:Interval ;
    rdfs:range time:Instant .

###  http://www.w3.org/2006/time#hasEnd
time:hasEnd rdf:type owl:ObjectProperty ;
    rdfs:domain time:Interval ;
    rdfs:range time:Instant .

###  http://www.w3.org/2006/vcard/ns#hasAddress
vcard:hasAddress rdf:type owl:ObjectProperty ;
    rdfs:domain <http://xmlns.com/foaf/0.1/Person> ;
    rdfs:range vcard:Address .

###  http://www.w3.org/ns/prov#wasAssociatedWith
prov:wasAssociatedWith rdf:type owl:ObjectProperty .

###  https://w3id.org/orda#communicationBetween
:communicationBetween rdf:type owl:ObjectProperty ;
    rdfs:domain :CommunicationEvent ;
    rdfs:range <http://xmlns.com/foaf/0.1/Agent> ;
    rdfs:label "communication between"@en .

###  https://w3id.org/orda#concerns
:concerns rdf:type owl:ObjectProperty ;
    rdfs:comment "Links a document or action to the dataset or resource it pertains to."@en ;
    rdfs:label "concerns"@en .

###  https://w3id.org/orda#decisionMadeBy
:decisionMadeBy rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf prov:wasAssociatedWith ;
    rdfs:domain :Decision ;
    rdfs:range <http://xmlns.com/foaf/0.1/Agent> ;
    rdfs:label "decision made by"@en .

###  https://w3id.org/orda#hasCommunication
:hasCommunication rdf:type owl:ObjectProperty ;
    rdfs:range :CommunicationEvent ;
    rdfs:label "has communication"@en .

###  https://w3id.org/orda#hasDecision
:hasDecision rdf:type owl:ObjectProperty ;
    rdfs:range :Decision ;
    rdfs:comment "Links a process event or phase to a formal Decision."@en ;
    rdfs:label "has decision"@en .

###  https://w3id.org/orda#hasDuration
:hasDuration rdf:type owl:ObjectProperty ;
    rdfs:domain time:Interval ;
    rdfs:range time:Duration ;
    rdfs:label "has duration"@en .

###  https://w3id.org/orda#hasEventType
:hasEventType rdf:type owl:ObjectProperty ;
    rdfs:domain :ProcessEvent ;
    rdfs:range :EventType ;
    rdfs:comment "Classifies a ProcessEvent using a controlled vocabulary of EventType individuals."@en ;
    rdfs:label "has event type"@en .

###  https://w3id.org/orda#hasOutput
:hasOutput rdf:type owl:ObjectProperty ;
    rdfs:domain time:Interval ;
    rdfs:range <http://xmlns.com/foaf/0.1/Document> ;
    rdfs:comment "Links a process phase to its document output."@en ;
    rdfs:label "has output"@en .

###  https://w3id.org/orda#hasSubPhase
:hasSubPhase rdf:type owl:ObjectProperty ;
    rdfs:domain time:Interval ;
    rdfs:range time:Interval ;
    rdfs:label "has sub-phase"@en .

###  https://w3id.org/orda#isTriggeredBy
:isTriggeredBy rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf time:hasBeginning ;
    rdfs:domain time:Interval ;
    rdfs:range :ProcessEvent ;
    rdfs:comment "Links a process phase to the ProcessEvent that marks its beginning. Subproperty of time:hasBeginning, aligning with OWL Time's interval/instant model."@en ;
    rdfs:label "is triggered by"@en .

###  https://w3id.org/orda#issuedBy
:issuedBy rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :performedBy ;
    rdfs:label "issued by"@en .

###  https://w3id.org/orda#occursWithin
:occursWithin rdf:type owl:ObjectProperty ;
    rdfs:domain :ProcessEvent ;
    rdfs:range time:Interval ;
    rdfs:comment "Links a ProcessEvent or document to the process phase in which it occurs."@en ;
    rdfs:label "occurs within"@en .

###  https://w3id.org/orda#performedBy
:performedBy rdf:type owl:ObjectProperty ;
    rdfs:range <http://xmlns.com/foaf/0.1/Agent> ;
    rdfs:label "performed by"@en .

###  https://w3id.org/orda#produces
:produces rdf:type owl:ObjectProperty ;
    rdfs:domain :ProcessEvent ;
    rdfs:range <http://xmlns.com/foaf/0.1/Document> ;
    rdfs:comment "Links a ProcessEvent to the document it produces as output."@en ;
    rdfs:label "produces"@en .

###  https://w3id.org/orda#submittedBy
:submittedBy rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :performedBy ;
    rdfs:label "submitted by"@en .


#################################################################
#    Data Properties
#################################################################

###  http://www.w3.org/2006/time#inXSDDateTimeStamp
time:inXSDDateTimeStamp rdf:type owl:DatatypeProperty ;
    rdfs:domain time:Instant ;
    rdfs:range xsd:dateTimeStamp ;
    rdfs:comment "The timestamp of a time:Instant, expressed as an XSD dateTimeStamp."@en ;
    rdfs:label "in XSD dateTimeStamp"@en .

###  http://www.w3.org/2006/vcard/ns#country-name
vcard:country-name rdf:type owl:DatatypeProperty ;
    rdfs:domain vcard:Address .

###  http://www.w3.org/2006/vcard/ns#locality
vcard:locality rdf:type owl:DatatypeProperty ;
    rdfs:domain vcard:Address .

###  http://www.w3.org/2006/vcard/ns#region
vcard:region rdf:type owl:DatatypeProperty ;
    rdfs:domain vcard:Address .

###  https://w3id.org/orda#decisionDate
:decisionDate rdf:type owl:DatatypeProperty ;
    rdfs:domain :Decision ;
    rdfs:range xsd:dateTime ;
    rdfs:label "decision date"@en .

###  https://w3id.org/orda#decisionOutcome
:decisionOutcome rdf:type owl:DatatypeProperty ;
    rdfs:domain :Decision ;
    rdfs:range xsd:string ;
    rdfs:comment "The result of a Decision: accepted, rejected, conditional."@en ;
    rdfs:label "decision outcome"@en .

###  https://w3id.org/orda#documentStage
:documentStage rdf:type owl:ObjectProperty ;
    rdfs:domain <http://xmlns.com/foaf/0.1/Document> ;
    rdfs:range :DocumentStage ;
    rdfs:comment "Links a document to its controlled DocumentStage individual. Use together with dcterms:isVersionOf to link versions."@en ;
    rdfs:label "document stage"@en .

###  https://w3id.org/orda#maxWorkingDays
:maxWorkingDays rdf:type owl:DatatypeProperty ;
    rdfs:domain time:Interval ;
    rdfs:range xsd:integer ;
    rdfs:comment "Statutory time limit for a process phase, expressed in working days."@en ;
    rdfs:label "maximum working days"@en .


#################################################################
#    Classes
#################################################################

###  http://www.w3.org/2006/time#Duration
time:Duration rdf:type owl:Class .

###  http://www.w3.org/2006/time#Instant
time:Instant rdf:type owl:Class .

###  http://www.w3.org/2006/time#Interval
time:Interval rdf:type owl:Class .

###  http://www.w3.org/2006/vcard/ns#Address
vcard:Address rdf:type owl:Class .

###  http://www.w3.org/ns/odrl/2/Request
odrl:Request rdf:type owl:Class .

###  http://www.w3.org/ns/prov#Activity
prov:Activity rdf:type owl:Class .

###  https://w3id.org/orda#AccessGranted
:AccessGranted rdf:type owl:Class ;
    rdfs:subClassOf :Decision ;
    owl:disjointWith :AccessRejected , :AccessRevoked ;
    rdfs:label "Access Granted"@en .

###  https://w3id.org/orda#AccessRejected
:AccessRejected rdf:type owl:Class ;
    rdfs:subClassOf :Decision ;
    owl:disjointWith :AccessRevoked ;
    rdfs:label "Access Rejected"@en .

###  https://w3id.org/orda#AccessRevoked
:AccessRevoked rdf:type owl:Class ;
    rdfs:subClassOf :Decision ;
    rdfs:label "Access Revoked"@en .

###  https://w3id.org/orda#AmendmentPhase
:AmendmentPhase rdf:type owl:Class ;
    rdfs:subClassOf :AuthorisationPhase ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty time:after ;
                      owl:someValuesFrom :VettingPhase ] ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty :isTriggeredBy ;
                      owl:someValuesFrom :ProcessEvent ] ;
    rdfs:comment "Data provider or researcher may submit amendment requests. Max. 15 days. Triggered by a ProcessEvent of type :ReasonedRequestIssued."@en ;
    rdfs:label "Amendment Phase"@en ;
    :hasLegalBasis "Art. 40(5) DSA"@en .

###  https://w3id.org/orda#AmendmentRequest
:AmendmentRequest rdf:type owl:Class ;
    rdfs:subClassOf <http://xmlns.com/foaf/0.1/Document> ;
    rdfs:comment "Submitted during the Amendment Phase by researcher or data provider."@en ;
    rdfs:label "Amendment Request"@en .

###  https://w3id.org/orda#ApplicantResearcher
:ApplicantResearcher rdf:type owl:Class ;
    rdfs:subClassOf :RequestingResearcher ;
    rdfs:comment "A collaborating researcher that is part of the principal researcher's data access application."@en ;
    rdfs:label "Applicant Researcher"@en .

###  https://w3id.org/orda#ApplicationDraftingPhase
:ApplicationDraftingPhase rdf:type owl:Class ;
    rdfs:subClassOf time:Interval ;
    rdfs:comment "Formulation and submission of the data access application by the Principal Researcher."@en ;
    rdfs:label "Application Drafting Phase"@en .

###  https://w3id.org/orda#AuthorisationPhase
:AuthorisationPhase rdf:type owl:Class ;
    rdfs:subClassOf time:Interval ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty time:after ;
                      owl:someValuesFrom :ApplicationDraftingPhase ] ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty :isTriggeredBy ;
                      owl:someValuesFrom :ProcessEvent ] ;
    rdfs:comment "Covers completeness check, vetting, reasoned request, amendments, and mediation. Triggered by a ProcessEvent of type :ApplicationSubmitted."@en ;
    rdfs:label "Authorisation Phase"@en ;
    :hasLegalBasis "Art. 40(4) DSA; DA"@en .

###  https://w3id.org/orda#CommunicationEvent
:CommunicationEvent rdf:type owl:Class ;
    rdfs:subClassOf prov:Activity ;
    rdfs:comment "An exchange between the platform and a researcher, modelled using schema:CommunicateAction semantics."@en ;
    rdfs:label "Communication Event"@en .

###  https://w3id.org/orda#CompletenessCheckPhase
:CompletenessCheckPhase rdf:type owl:Class ;
    rdfs:subClassOf :AuthorisationPhase ;
    rdfs:comment "DSC-M and DSC-E verify completeness of the application."@en ;
    rdfs:label "Completeness Check Phase"@en .

###  https://w3id.org/orda#DataAccessApplication
:DataAccessApplication rdf:type owl:Class ;
    rdfs:subClassOf odrl:Request ,
                    <http://xmlns.com/foaf/0.1/Document> ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty :submittedBy ;
                      owl:someValuesFrom :PrincipalResearcher ] ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty :documentStage ;
                      owl:allValuesFrom [ rdf:type owl:Class ;
                                          owl:oneOf ( :StageDraft :StageSubmitted :StageAmended ) ] ] ;
    rdfs:comment "The formal application submitted by the Principal Researcher to a DSC."@en ;
    rdfs:label "Data Access Application"@en .

###  https://w3id.org/orda#DataAccessPhase
:DataAccessPhase rdf:type owl:Class ;
    rdfs:subClassOf time:Interval ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty time:after ;
                      owl:someValuesFrom :AuthorisationPhase ] ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty :isTriggeredBy ;
                      owl:someValuesFrom :ProcessEvent ] ;
    rdfs:comment "Period during which access is granted, exercised, ended, or revoked. Triggered by a ProcessEvent of type :AccessGrantedEvent."@en ;
    rdfs:label "Data Access Phase"@en .

###  https://w3id.org/orda#DataProvider
:DataProvider rdf:type owl:Class ;
    rdfs:subClassOf <http://xmlns.com/foaf/0.1/Organization> ;
    rdfs:comment "The organisation holding the data subject to the access request."@en ;
    rdfs:label "Data Provider"@en .

###  https://w3id.org/orda#Decision
:Decision rdf:type owl:Class ;
    rdfs:subClassOf prov:Activity ;
    rdfs:comment "A formal decision taken by an authorised agent within a process phase. Modelled separately from documents to capture provenance, conditions, and revisability."@en ;
    rdfs:label "Decision"@en .

###  https://w3id.org/orda#DigitalServicesCoordinator
:DigitalServicesCoordinator rdf:type owl:Class ;
    rdfs:subClassOf <http://xmlns.com/foaf/0.1/Organization> ;
    rdfs:comment "A Digital Services Coordinator as set out in Art. 49(2) DSA."@en ;
    rdfs:label "Digital Services Coordinator"@en ;
    :hasLegalBasis "Art. 49(2) DSA"@en .

###  https://w3id.org/orda#DigitalServicesCoordinatorOfEstablishment
:DigitalServicesCoordinatorOfEstablishment rdf:type owl:Class ;
    rdfs:subClassOf :DigitalServicesCoordinator ;
    rdfs:comment "DSC-E: primary vetting body responsible for formulating the reasoned request."@en ;
    rdfs:label "DSC of Establishment"@en .

###  https://w3id.org/orda#DigitalServicesCoordinatorOfMemberState
:DigitalServicesCoordinatorOfMemberState rdf:type owl:Class ;
    rdfs:subClassOf :DigitalServicesCoordinator ;
    rdfs:comment "DSC-M: performs the completeness check on the application."@en ;
    rdfs:label "DSC of Member State"@en .

###  https://w3id.org/orda#DocumentStage
:DocumentStage rdf:type owl:Class ;
    rdfs:comment "A controlled vocabulary class for typing the procedural stage of a document. Instances are named individuals. Not all stages are valid for all document types — see allValuesFrom restrictions on each document class."@en ;
    rdfs:label "Document Stage"@en .

###  https://w3id.org/orda#EventType
:EventType rdf:type owl:Class ;
    rdfs:comment "A controlled vocabulary class for typing ProcessEvent individuals. Instances are named individuals representing key moments in the data access process."@en ;
    rdfs:label "Event Type"@en .

###  https://w3id.org/orda#MediationPhase
:MediationPhase rdf:type owl:Class ;
    rdfs:subClassOf :AuthorisationPhase ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty time:after ;
                      owl:someValuesFrom :AmendmentPhase ] ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty :isTriggeredBy ;
                      owl:someValuesFrom :ProcessEvent ] ;
    rdfs:comment "Mediation requested within max. 5 working days; conducted within max. 40 working days. Triggered by a ProcessEvent of type :MediationRequested."@en ;
    rdfs:label "Mediation Phase"@en ;
    :hasLegalBasis "Art. 13(1) DA"@en .

###  https://w3id.org/orda#MediationRequest
:MediationRequest rdf:type owl:Class ;
    rdfs:subClassOf <http://xmlns.com/foaf/0.1/Document> ;
    rdfs:comment "Filed within max. 5 working days of triggering event."@en ;
    rdfs:label "Request for Mediation"@en ;
    :hasLegalBasis "Art. 13(1) DA"@en .

###  https://w3id.org/orda#Mediator
:Mediator rdf:type owl:Class ;
    rdfs:subClassOf <http://xmlns.com/foaf/0.1/Agent> ;
    rdfs:comment "An independent agent conducting mediation between DSC-E and the data provider."@en ;
    rdfs:label "Mediator"@en .

###  https://w3id.org/orda#PrincipalResearcher
:PrincipalResearcher rdf:type owl:Class ;
    rdfs:subClassOf :RequestingResearcher ;
    rdfs:comment "The lead researcher responsible for submitting and managing the data access application."@en ;
    rdfs:label "Principal Researcher"@en .

###  https://w3id.org/orda#ProcessEvent
:ProcessEvent rdf:type owl:Class ;
    rdfs:subClassOf time:Instant ;
    rdfs:comment "A key instantaneous moment within the data access process, typed by a controlled EventType individual. Carries a timestamp via time:inXSDDateTimeStamp and is linked to the agent who performed it via :performedBy."@en ;
    rdfs:label "Process Event"@en .

###  https://w3id.org/orda#ReasonedRequest
:ReasonedRequest rdf:type owl:Class ;
    rdfs:subClassOf <http://xmlns.com/foaf/0.1/Document> ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty :issuedBy ;
                      owl:someValuesFrom :DigitalServicesCoordinatorOfEstablishment ] ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty :documentStage ;
                      owl:allValuesFrom [ rdf:type owl:Class ;
                                          owl:oneOf ( :StageInitial :StageAmended :StageMediated ) ] ] ;
    rdfs:comment "Issued by DSC-E following vetting. Use :documentStage to distinguish initial, amended, and mediated versions. Use dcterms:isVersionOf to link versions to each other."@en ;
    rdfs:label "Reasoned Request"@en ;
    :hasLegalBasis "Art. 40(4) DSA; Art. 7(2) DA"@en .

###  https://w3id.org/orda#RequestingResearcher
:RequestingResearcher rdf:type owl:Class ;
    rdfs:subClassOf :Researcher ;
    rdfs:comment "A researcher who has initiated or is party to a data access request."@en ;
    rdfs:label "Requesting Researcher"@en .

###  https://w3id.org/orda#Researcher
:Researcher rdf:type owl:Class ;
    rdfs:subClassOf <http://xmlns.com/foaf/0.1/Person> ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty vcard:hasAddress ;
                      owl:someValuesFrom vcard:Address ] ;
    rdfs:label "Researcher"@en .

###  https://w3id.org/orda#VeryLargeOnlinePlatform
:VeryLargeOnlinePlatform rdf:type owl:Class ;
    rdfs:subClassOf :DataProvider ;
    rdfs:label "Very Large Online Platform"@en ;
    rdfs:comment "Designated online platforms with equal to or more than 45 million average monthly active recipients of the service in the Union."@en ;
    :hasLegalBasis "Art. 33 DSA"@en .

###  https://w3id.org/orda#VeryLargeOnlineSearchEngine
:VeryLargeOnlineSearchEngine rdf:type owl:Class ;
    rdfs:subClassOf :DataProvider ;
    rdfs:label "Very Large Online Search Engine"@en ;
    rdfs:comment "Designated online search engines with equal to or more than 45 million average monthly active recipients of the service in the Union."@en ;
    :hasLegalBasis "Art. 33 DSA"@en .

###  https://w3id.org/orda#VettedResearcher
:VettedResearcher rdf:type owl:Class ;
    rdfs:subClassOf :Researcher ;
    rdfs:comment "A researcher who has successfully completed the vetting process."@en ;
    rdfs:label "Vetted Researcher"@en .

###  https://w3id.org/orda#VettingPhase
:VettingPhase rdf:type owl:Class ;
    rdfs:subClassOf :AuthorisationPhase ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty time:after ;
                      owl:someValuesFrom :CompletenessCheckPhase ] ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty :isTriggeredBy ;
                      owl:someValuesFrom :ProcessEvent ] ;
    rdfs:comment "DSC-E formulates and issues the initial reasoned request. Max. 80 working days. Triggered by a ProcessEvent of type :CompletenessCheckPassed."@en ;
    rdfs:label "Vetting Phase"@en ;
    :hasLegalBasis "Art. 40(4) DSA; Art. 7(2) DA"@en .


#################################################################
#    Individuals
#################################################################

#-- DocumentStage controlled vocabulary --

###  https://w3id.org/orda#StageDraft
:StageDraft rdf:type owl:NamedIndividual , :DocumentStage ;
    rdfs:label "Draft"@en ;
    rdfs:comment "The document is being prepared but has not yet been submitted. Valid for DataAccessApplication."@en .

###  https://w3id.org/orda#StageSubmitted
:StageSubmitted rdf:type owl:NamedIndividual , :DocumentStage ;
    rdfs:label "Submitted"@en ;
    rdfs:comment "The document has been formally submitted. Valid for DataAccessApplication."@en .

###  https://w3id.org/orda#StageAmended
:StageAmended rdf:type owl:NamedIndividual , :DocumentStage ;
    rdfs:label "Amended"@en ;
    rdfs:comment "The document has been revised following a request for changes. Valid for DataAccessApplication and ReasonedRequest."@en .

###  https://w3id.org/orda#StageInitial
:StageInitial rdf:type owl:NamedIndividual , :DocumentStage ;
    rdfs:label "Initial"@en ;
    rdfs:comment "The first issued version of the document. Valid for ReasonedRequest."@en .

###  https://w3id.org/orda#StageMediated
:StageMediated rdf:type owl:NamedIndividual , :DocumentStage ;
    rdfs:label "Mediated"@en ;
    rdfs:comment "The version produced following mediation. Exclusive to ReasonedRequest."@en .

#-- EventType controlled vocabulary --

###  https://w3id.org/orda#ApplicationSubmitted
:ApplicationSubmitted rdf:type owl:NamedIndividual , :EventType ;
    rdfs:label "Application Submitted"@en ;
    rdfs:comment "The Principal Researcher submits the data access application. Triggers the Authorisation Phase."@en .

###  https://w3id.org/orda#CompletenessCheckPassed
:CompletenessCheckPassed rdf:type owl:NamedIndividual , :EventType ;
    rdfs:label "Completeness Check Passed"@en ;
    rdfs:comment "DSC-M and DSC-E confirm the application is complete. Triggers the Vetting Phase."@en .

###  https://w3id.org/orda#ReasonedRequestIssued
:ReasonedRequestIssued rdf:type owl:NamedIndividual , :EventType ;
    rdfs:label "Reasoned Request Issued"@en ;
    rdfs:comment "DSC-E issues the initial reasoned request. Triggers the Amendment Phase."@en .

###  https://w3id.org/orda#AmendmentRequestSubmitted
:AmendmentRequestSubmitted rdf:type owl:NamedIndividual , :EventType ;
    rdfs:label "Amendment Request Submitted"@en ;
    rdfs:comment "Researcher or data provider submits an amendment request during the Amendment Phase."@en .

###  https://w3id.org/orda#MediationRequested
:MediationRequested rdf:type owl:NamedIndividual , :EventType ;
    rdfs:label "Mediation Requested"@en ;
    rdfs:comment "A party requests mediation within max. 5 working days. Triggers the Mediation Phase."@en ;
    :hasLegalBasis "Art. 13(1) DA"@en .

###  https://w3id.org/orda#MediationConcluded
:MediationConcluded rdf:type owl:NamedIndividual , :EventType ;
    rdfs:label "Mediation Concluded"@en ;
    rdfs:comment "The mediator issues the result. Ends the Mediation Phase."@en .

###  https://w3id.org/orda#AccessGrantedEvent
:AccessGrantedEvent rdf:type owl:NamedIndividual , :EventType ;
    rdfs:label "Access Granted"@en ;
    rdfs:comment "DSC-E grants data access. Triggers the Data Access Phase."@en .

###  https://w3id.org/orda#AccessEndedEvent
:AccessEndedEvent rdf:type owl:NamedIndividual , :EventType ;
    rdfs:label "Access Ended"@en ;
    rdfs:comment "The data access period ends as specified in the reasoned request. Ends the Data Access Phase."@en .

###  https://w3id.org/orda#AccessRevokedEvent
:AccessRevokedEvent rdf:type owl:NamedIndividual , :EventType ;
    rdfs:label "Access Revoked"@en ;
    rdfs:comment "Access is revoked before the end of the agreed period. Ends the Data Access Phase."@en .

#-- Phase statutory limit individuals --

###  https://w3id.org/orda#AmendmentPhaseInstance
:AmendmentPhaseInstance rdf:type owl:NamedIndividual , :AmendmentPhase ;
    :maxWorkingDays 15 ;
    rdfs:label "Amendment Phase (statutory limit)"@en .

###  https://w3id.org/orda#MediationPhaseInstance
:MediationPhaseInstance rdf:type owl:NamedIndividual , :MediationPhase ;
    :maxWorkingDays 40 ;
    rdfs:label "Mediation Phase (statutory limit)"@en .

###  https://w3id.org/orda#VettingPhaseInstance
:VettingPhaseInstance rdf:type owl:NamedIndividual , :VettingPhase ;
    :maxWorkingDays 80 ;
    rdfs:label "Vetting Phase (statutory limit)"@en .