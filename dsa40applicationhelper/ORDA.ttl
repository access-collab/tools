<https://w3id.org/cerif2/Resource_Identifier> rdf:type owl:Class ;
                                              rdfs:isDefinedBy <https://w3id.org/cerif2/> ;
                                              rdfs:label "Resource Identifier"@en .


###  https://w3id.org/dpv/legal/eu#DSA
<https://w3id.org/dpv/legal/eu#DSA> rdf:type owl:Class .


###  https://w3id.org/dpv/owl#LegalBasis
<https://w3id.org/dpv/owl#LegalBasis> rdf:type owl:Class .


###  https://w3id.org/orda#APIDistribution
:APIDistribution rdf:type owl:Class ;
                 rdfs:subClassOf <http://www.w3.org/ns/dcat#Distribution> ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty dcterms:hasFormat ;
                                   owl:someValuesFrom <https://w3id.org/cerif2/Document>
                                 ] ;
                 rdfs:comment "A dcat:Distribution accessible via an API; dcterms:hasFormat links to an OpenAPI or JSON Schema cerif:Document."@en ;
                 rdfs:label "API Distribution"@en .


###  https://w3id.org/orda#AccessEndedEvent
:AccessEndedEvent rdf:type owl:Class ;
                  rdfs:subClassOf :TriggerActivity ;
                  rdfs:comment "The data access period ends as specified in the reasoned request. Ends the Data Access Phase."@en ;
                  rdfs:label "Access Ended"@en .


###  https://w3id.org/orda#AccessGrantedDecision
:AccessGrantedDecision rdf:type owl:Class ;
                       rdfs:subClassOf :Decision ;
                       owl:disjointWith :AccessGrantedEvent ,
                                        :AccessRejectedDecision ,
                                        :AccessRevokedDecision ;
                       rdfs:comment "Outcome: DSC-E grants access. Distinct from :AccessGrantedEvent (phase trigger)."@en ;
                       rdfs:label "Access Granted Decision"@en .


###  https://w3id.org/orda#AccessGrantedEvent
:AccessGrantedEvent rdf:type owl:Class ;
                    rdfs:subClassOf :TriggerActivity ;
                    owl:disjointWith :AccessRejectedDecision ,
                                     :AccessRevokedDecision ;
                    rdfs:comment "DSC-E grants data access. Triggers the Data Access Phase. Distinct from the :AccessGrantedDecision outcome class."@en ;
                    rdfs:label "Access Granted (trigger)"@en .


###  https://w3id.org/orda#AccessInterface
:AccessInterface rdf:type owl:Class ;
                 rdfs:subClassOf :TechnicalModality ;
                 rdfs:comment "A concrete technical means of obtaining data, e.g. REST API, web scraping, bulk download, secure research environment."@en ;
                 rdfs:label "Access Interface"@en .


###  https://w3id.org/orda#AccessModality
:AccessModality rdf:type owl:Class ;
                rdfs:subClassOf odrl:Set ;
                rdfs:comment "Technical, legal or organisational access arrangement (DA Art. 9), modelled as an ODRL Set of rules. Proposals use :ProposedAccessOffer (odrl:Offer); DSC-determined terms use :DeterminedAccessOffer; granted access is recorded with :hasAccessAgreement (odrl:Agreement)."@en ;
                rdfs:label "Access Modality"@en .


###  https://w3id.org/orda#ProposedAccessOffer
:ProposedAccessOffer rdf:type owl:Class ;
                     rdfs:subClassOf :AccessModality ,
                                     odrl:Offer ;
                     rdfs:comment "Researcher-proposed access terms linked from :DataAccessApplication via :suggestsModality."@en ;
                     rdfs:label "Proposed Access Offer"@en .


###  https://w3id.org/orda#DeterminedAccessOffer
:DeterminedAccessOffer rdf:type owl:Class ;
                      rdfs:subClassOf :AccessModality ,
                                      odrl:Offer ;
                      rdfs:comment "DSC-E-determined access terms linked from :ReasonedRequest via :hasAccessModality."@en ;
                      rdfs:label "Determined Access Offer"@en .


###  https://w3id.org/orda#AccessRejectedDecision
:AccessRejectedDecision rdf:type owl:Class ;
                        rdfs:subClassOf :Decision ;
                        owl:disjointWith :AccessRevokedDecision ;
                        rdfs:comment "Outcome: access is rejected."@en ;
                        rdfs:label "Access Rejected Decision"@en .


###  https://w3id.org/orda#AccessRevokedDecision
:AccessRevokedDecision rdf:type owl:Class ;
                       rdfs:subClassOf :Decision ;
                       rdfs:comment "Outcome: access is revoked before the agreed end date."@en ;
                       rdfs:label "Access Revoked Decision"@en .


###  https://w3id.org/orda#AccessRevokedEvent
:AccessRevokedEvent rdf:type owl:Class ;
                    rdfs:subClassOf :TriggerActivity ;
                    rdfs:comment "Access is revoked before the end of the agreed period. Ends the Data Access Phase."@en ;
                    rdfs:label "Access Revoked"@en .


###  https://w3id.org/orda#AdvertisingSystemsMitigation
:AdvertisingSystemsMitigation rdf:type owl:Class ;
                              rdfs:subClassOf :MitigationMeasureCategory ;
                              rdfs:comment "Adapting their advertising systems and adopting targeted measures aimed at limiting or adjusting the presentation of advertisements in association with the service they provide."@en ;
                              rdfs:label "Advertising systems mitigation"@en .


###  https://w3id.org/orda#AlgorithmicSystemsMitigation
:AlgorithmicSystemsMitigation rdf:type owl:Class ;
                              rdfs:subClassOf :MitigationMeasureCategory ;
                              rdfs:comment "Testing and adapting their algorithmic systems, including their recommender systems."@en ;
                              rdfs:label "Algorithmic systems mitigation"@en .


###  https://w3id.org/orda#AmendmentPhase
:AmendmentPhase rdf:type owl:Class ;
                rdfs:subClassOf :AuthorisationPhase ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty time:after ;
                                  owl:someValuesFrom :VettingPhase
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty <https://w3id.org/dpv/owl#hasLegalBasis> ;
                                  owl:someValuesFrom <https://w3id.org/dpv/legal/eu#DSA>
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :isTriggeredBy ;
                                  owl:someValuesFrom :ReasonedRequestIssued
                                ] ;
                rdfs:comment "Data provider or researcher may submit amendment requests. Max. 15 days. Triggered by a :ReasonedRequestIssued activity. Legal basis: Article 40, paragraph 5, of the DSA."@en ;
                rdfs:label "Amendment Phase"@en .


###  https://w3id.org/orda#AmendmentRequest
:AmendmentRequest rdf:type owl:Class ;
                  rdfs:subClassOf :ProcessDocument ;
                  rdfs:comment "Submitted during the Amendment Phase by researcher or data provider."@en ;
                  rdfs:label "Amendment Request"@en .


###  https://w3id.org/orda#AmendmentRequestSubmitted
:AmendmentRequestSubmitted rdf:type owl:Class ;
                           rdfs:subClassOf :TriggerActivity ;
                           rdfs:comment "Researcher or data provider submits an amendment request during the Amendment Phase."@en ;
                           rdfs:label "Amendment Request Submitted"@en .


###  https://w3id.org/orda#ApplicantResearcher
:ApplicantResearcher rdf:type owl:Class ;
                     rdfs:subClassOf :RequestingResearcher ;
                     rdfs:comment "A collaborating researcher that is part of the principal researcher's data access application."@en ;
                     rdfs:label "Applicant Researcher"@en .


###  https://w3id.org/orda#ApplicationDraftingPhase
:ApplicationDraftingPhase rdf:type owl:Class ;
                          rdfs:subClassOf time:Interval ;
                          rdfs:comment "Formulation and submission of the data access application by the Principal Researcher. Occurs in both Art. 40(4) and Art. 40(12) processes."@en ;
                          rdfs:label "Application Drafting Phase"@en .


###  https://w3id.org/orda#ApplicationSubmitted
:ApplicationSubmitted rdf:type owl:Class ;
                      rdfs:subClassOf :TriggerActivity ;
                      rdfs:comment "The Principal Researcher submits the data access application. Triggers the Authorisation Phase."@en ;
                      rdfs:label "Application Submitted"@en .


###  https://w3id.org/orda#Art40_12_DataAccessProcess
:Art40_12_DataAccessProcess rdf:type owl:Class ;
                            rdfs:subClassOf :DataAccessProcess ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty <https://w3id.org/dpv/owl#hasLegalBasis> ;
                                              owl:someValuesFrom <https://w3id.org/dpv/legal/eu#DSA>
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty :hasFormalRequest ;
                                              owl:allValuesFrom :Art40_12_DataAccessRequest
                                            ] ;
                            rdfs:comment "Public-data access under Art. 40(12): submitted directly to the platform; the platform vets the request. Researchers cannot use the Art. 40(4) DSC/DA procedure; if dissatisfied they may file a :Complaint to the European Commission and relevant DSCs via :ComplaintFiling."@en ;
                            rdfs:label "Art. 40(12) Data Access Process"@en .


###  https://w3id.org/orda#Art40_12_DataAccessRequest
:Art40_12_DataAccessRequest rdf:type owl:Class ;
                            rdfs:subClassOf :DataAccessRequest ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty <https://w3id.org/dpv/owl#hasLegalBasis> ;
                                              owl:someValuesFrom <https://w3id.org/dpv/legal/eu#DSA>
                                            ] ;
                            rdfs:comment "Art. 40(12) DSA: public data access. The associated :ResearchProject contributes to the detection, identification and understanding of systemic risks in the Union pursuant to Article 34(1). Use :addressesSystemicRiskCategory for Art. 34(1) categories. Not governed by Delegated Regulation 2025/2050."@en ;
                            rdfs:label "Art. 40(12) Data Access Request"@en .


###  https://w3id.org/orda#Art40_4_DataAccessProcess
:Art40_4_DataAccessProcess rdf:type owl:Class ;
                           rdfs:subClassOf :DataAccessProcess ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty <https://w3id.org/dpv/owl#hasLegalBasis> ;
                                             owl:someValuesFrom <https://w3id.org/dpv/legal/eu#DSA>
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty <https://w3id.org/dpv/owl#hasLegalBasis> ;
                                             owl:someValuesFrom :DataAccessDelegatedRegulation
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty :hasFormalRequest ;
                                             owl:allValuesFrom :Art40_4_DataAccessRequest
                                           ] ;
                           rdfs:comment "Non-public data access under Art. 40(4) and Delegated Regulation 2025/2050: DSC completeness check, vetting, reasoned request, amendments, mediation, and data access phases modelled in this ontology."@en ;
                           rdfs:label "Art. 40(4) Data Access Process"@en ;
                           rdfs:seeAlso <http://data.europa.eu/eli/reg_del/2025/2050/oj> .


###  https://w3id.org/orda#Art40_4_DataAccessRequest
:Art40_4_DataAccessRequest rdf:type owl:Class ;
                           rdfs:subClassOf :DataAccessRequest ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty <https://w3id.org/dpv/owl#hasLegalBasis> ;
                                             owl:someValuesFrom <https://w3id.org/dpv/legal/eu#DSA>
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty <https://w3id.org/dpv/owl#hasLegalBasis> ;
                                             owl:someValuesFrom :DataAccessDelegatedRegulation
                                           ] ;
                           rdfs:comment "Art. 40(4) DSA: non-public data via DSC. The associated :ResearchProject contributes to the detection, identification and understanding of systemic risks in the Union as set out pursuant to Article 34(1), and to the assessment of the adequacy, efficiency and impacts of risk mitigation measures pursuant to Article 35. Use :addressesSystemicRiskCategory and :assessesMitigationMeasures. Governed by Delegated Regulation 2025/2050."@en ;
                           rdfs:label "Art. 40(4) Data Access Request"@en ;
                           rdfs:seeAlso <http://data.europa.eu/eli/reg/2022/2065/oj> ,
                                        <http://data.europa.eu/eli/reg_del/2025/2050/oj> .


###  https://w3id.org/orda#AuthorisationPhase
:AuthorisationPhase rdf:type owl:Class ;
                    rdfs:subClassOf time:Interval ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty time:after ;
                                      owl:someValuesFrom :ApplicationDraftingPhase
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty <https://w3id.org/dpv/owl#hasLegalBasis> ;
                                      owl:someValuesFrom <https://w3id.org/dpv/legal/eu#DSA>
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty <https://w3id.org/dpv/owl#hasLegalBasis> ;
                                      owl:someValuesFrom :DataAccessDelegatedRegulation
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty :isTriggeredBy ;
                                      owl:someValuesFrom :ApplicationSubmitted
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty :occursInProcess ;
                                      owl:someValuesFrom :Art40_4_DataAccessProcess
                                    ] ;
                    rdfs:comment "Covers completeness check, vetting, reasoned request, amendments, and mediation. Triggered by an :ApplicationSubmitted activity."@en ;
                    rdfs:label "Authorisation Phase"@en .


###  https://w3id.org/orda#AwarenessRaisingMitigation
:AwarenessRaisingMitigation rdf:type owl:Class ;
                            rdfs:subClassOf :MitigationMeasureCategory ;
                            rdfs:comment "Taking awareness-raising measures and adapting their online interface in order to give recipients of the service more information."@en ;
                            rdfs:label "Awareness-raising mitigation"@en .


###  https://w3id.org/orda#CDSMDirective
:CDSMDirective rdf:type owl:Class .


###  https://w3id.org/orda#CSVDistribution
:CSVDistribution rdf:type owl:Class ;
                 rdfs:subClassOf <http://www.w3.org/ns/dcat#Distribution> ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty dcterms:hasFormat ;
                                   owl:someValuesFrom <http://www.w3.org/ns/csvw#Schema>
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty dcterms:format ;
                                   owl:hasValue <http://publications.europa.eu/resource/authority/file-type/CSV>
                                 ] ;
                 rdfs:comment "CSV distribution with csvw:Schema via dct:hasFormat. Attach :hasQualityAssessment for documented data quality limitations."@en ;
                 rdfs:label "CSV Distribution"@en ;
                 rdfs:seeAlso <https://www.w3.org/ns/csvw> .


###  https://w3id.org/orda#ChildProtectionMitigation
:ChildProtectionMitigation rdf:type owl:Class ;
                           rdfs:subClassOf :MitigationMeasureCategory ;
                           rdfs:comment "Taking targeted measures to protect the rights of the child, including age verification and parental control tools, tools aimed at helping minors signal abuse or obtain support, as appropriate."@en ;
                           rdfs:label "Child protection mitigation"@en .


###  https://w3id.org/orda#CivicDiscourseRisk
:CivicDiscourseRisk rdf:type owl:Class ;
                    rdfs:subClassOf :SystemicRiskCategory ;
                    rdfs:comment "Negative effects on civic discourse (Art. 34(1)(c))."@en ;
                    rdfs:label "Civic Discourse Risk"@en .


###  https://w3id.org/orda#CommunicationEvent
:CommunicationEvent rdf:type owl:Class ;
                    rdfs:subClassOf :ProcessActivity ;
                    rdfs:comment "An exchange between the platform and a researcher, modelled as a :ProcessActivity with agents linked via :communicationBetween."@en ;
                    rdfs:label "Communication Event"@en .


###  https://w3id.org/orda#Complaint
:Complaint rdf:type owl:Class ;
           rdfs:subClassOf :ProcessDocument ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty <https://w3id.org/dpv/owl#hasLegalBasis> ;
                             owl:someValuesFrom <https://w3id.org/dpv/legal/eu#DSA>
                           ] ;
           rdfs:comment "A formal complaint filed with the European Commission and/or relevant DSCs when Art. 40(12) public-data access is unsatisfactory. Not part of the Art. 40(4) DA procedure."@en ;
           rdfs:label "Complaint"@en .


###  https://w3id.org/orda#ComplaintFiling
:ComplaintFiling rdf:type owl:Class ;
                 rdfs:subClassOf :TriggerActivity ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty <https://w3id.org/dpv/owl#hasLegalBasis> ;
                                   owl:someValuesFrom <https://w3id.org/dpv/legal/eu#DSA>
                                 ] ;
                 rdfs:comment "A researcher files a :Complaint with the European Commission and/or relevant DSCs under the Art. 40(12) process."@en ;
                 rdfs:label "Complaint Filing"@en .


###  https://w3id.org/orda#CompletenessCheckPassed
:CompletenessCheckPassed rdf:type owl:Class ;
                         rdfs:subClassOf :TriggerActivity ;
                         rdfs:comment "DSC-M and DSC-E confirm the application is complete. Triggers the Vetting Phase."@en ;
                         rdfs:label "Completeness Check Passed"@en .


###  https://w3id.org/orda#CompletenessCheckPhase
:CompletenessCheckPhase rdf:type owl:Class ;
                        rdfs:subClassOf :AuthorisationPhase ;
                        rdfs:comment "DSC-M and DSC-E verify completeness of the application. Art. 40(4) only."@en ;
                        rdfs:label "Completeness Check Phase"@en .


###  https://w3id.org/orda#ContentModerationMitigation
:ContentModerationMitigation rdf:type owl:Class ;
                             rdfs:subClassOf :MitigationMeasureCategory ;
                             rdfs:comment "Adapting content moderation processes, including the speed and quality of processing notices related to specific types of illegal content and, where appropriate, the expeditious removal of, or the disabling of access to, the content notified, in particular in respect of illegal hate speech or cyber violence, as well as adapting any relevant decision-making processes and dedicated resources for content moderation."@en ;
                             rdfs:label "Content moderation mitigation"@en .


###  https://w3id.org/orda#DSADataAccessPortal
:DSADataAccessPortal rdf:type owl:Class ;
                     rdfs:comment "Centralised infrastructure for Art. 40(4) application submission, process management, and publication of reasoned-request overviews (DA Art. 3, 11). Operated by the European Commission; link instances with :operatedBy."@en ;
                     rdfs:label "DSA Data Access Portal"@en ;
                     rdfs:seeAlso <http://data.europa.eu/eli/reg_del/2025/2050/oj> .


###  https://w3id.org/orda#DSADataCatalogue
:DSADataCatalogue rdf:type owl:Class ;
                  rdfs:subClassOf :DataCatalogue ;
                  rdfs:comment "Platform data catalogue per DA Art. 6(4). Distributions may carry :hasQualityAssessment annotations documenting known completeness, timeliness, or other limitations."@en ;
                  rdfs:label "DSA Data Catalogue"@en .


###  https://w3id.org/orda#DSALegalProvision
:DSALegalProvision rdf:type owl:Class ;
                   rdfs:subClassOf <http://data.europa.eu/eli/ontology#LegalResourceSubdivision> ,
                                   <https://w3id.org/dpv/owl#LegalBasis> ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty <http://data.europa.eu/eli/ontology#is_part_of> ;
                                     owl:hasValue <https://w3id.org/dpv/legal/eu#DSA>
                                   ] ;
                   rdfs:comment "A specific article or paragraph of the DSA, modelled as an ELI subdivision of legal-eu:DSA and a dpv:LegalBasis."@en ;
                   rdfs:label "DSA Legal Provision"@en .


###  https://w3id.org/orda#DataAccessApplication
:DataAccessApplication rdf:type owl:Class ;
                       rdfs:subClassOf odrl:Request ,
                                       :ProcessDocument ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty :submittedBy ;
                                         owl:someValuesFrom :PrincipalResearcher
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty :documentStage ;
                                         owl:allValuesFrom [ rdf:type owl:Class ;
                                                             owl:oneOf ( :StageAmended
                                                                         :StageDraft
                                                                         :StageSubmitted
                                                                       )
                                                           ]
                                       ] ;
                       rdfs:comment "Formal application document. Carries application content (:independenceDeclaration, :hasPublicationCommitment, :publicationTimeline), data requests (:requestsData), catalogue references (:referencesDataCatalogue), and proposed modalities (:suggestsModality)."@en ;
                       rdfs:label "Data Access Application"@en .


###  https://w3id.org/orda#DataAccessDelegatedRegulation
:DataAccessDelegatedRegulation rdf:type owl:Class .


###  https://w3id.org/orda#DataAccessPhase
:DataAccessPhase rdf:type owl:Class ;
                 rdfs:subClassOf time:Interval ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty time:after ;
                                   owl:someValuesFrom :AuthorisationPhase
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :isTriggeredBy ;
                                   owl:someValuesFrom :AccessGrantedEvent
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :occursInProcess ;
                                   owl:someValuesFrom :Art40_4_DataAccessProcess
                                 ] ;
                 rdfs:comment "Period during which access is granted, exercised, ended, or revoked. Triggered by an :AccessGrantedEvent trigger activity."@en ;
                 rdfs:label "Data Access Phase"@en .


###  https://w3id.org/orda#DataAccessProcess
:DataAccessProcess rdf:type owl:Class ;
                   rdfs:comment "A procedural workflow for obtaining platform data under a specific Art. 40 legal basis. Use :Art40_4_DataAccessProcess or :Art40_12_DataAccessProcess; link phases via :hasPhase, the formal request via :hasFormalRequest, and the parent :ResearchProject via :hasDataAccessProcess."@en ;
                   rdfs:label "Data Access Process"@en .


###  https://w3id.org/orda#DataAccessRequest
:DataAccessRequest rdf:type owl:Class ;
                   rdfs:subClassOf [ rdf:type owl:Restriction ;
                                     owl:onProperty <https://w3id.org/dpv/owl#hasLegalBasis> ;
                                     owl:someValuesFrom <https://w3id.org/dpv/legal/eu#DSA>
                                   ] ;
                   rdfs:comment "A formal request by a researcher to access data from a VLOP or VLOSE under DSA Art. 40. Superclass for Art. 40(4) and Art. 40(12) requests."@en ;
                   rdfs:label "Data Access Request"@en .


###  https://w3id.org/orda#DataCatalogue
:DataCatalogue rdf:type owl:Class ;
               rdfs:subClassOf <http://www.w3.org/ns/dcat#Catalog> ;
               rdfs:label "Data Catalogue"@en .


###  https://w3id.org/orda#DataManagementPlan
:DataManagementPlan rdf:type owl:Class ;
                    rdfs:subClassOf :ProcessDocument ;
                    rdfs:comment "Plan governing storage, processing and protection of accessed data."@en ;
                    rdfs:label "Data Management Plan"@en .


###  https://w3id.org/orda#DataProtectionAuthority
:DataProtectionAuthority rdf:type owl:Class ;
                         rdfs:subClassOf :RegulatoryAuthority ;
                         owl:disjointWith :ResearchOrganisation ;
                         rdfs:comment "Independent supervisory authority under Regulation (EU) 2016/679 (GDPR) or Directive (EU) 2016/680 (LED). Distinct from :DigitalServicesCoordinator."@en ;
                         rdfs:label "Data Protection Authority"@en ;
                         rdfs:seeAlso <http://data.europa.eu/eli/reg/2016/679/oj> .


###  https://w3id.org/orda#DataProtectionConsultation
:DataProtectionConsultation rdf:type owl:Class ;
                            rdfs:subClassOf :ProcessActivity ;
                            rdfs:comment "Consultation with a data protection authority on GDPR/LED aspects of an Art. 40(4) request."@en ;
                            rdfs:label "Data Protection Consultation"@en .


###  https://w3id.org/orda#DataProvider
:DataProvider rdf:type owl:Class ;
              rdfs:subClassOf <https://w3id.org/cerif2/Organisation_Unit> ;
              owl:disjointWith :ResearchOrganisation ;
              rdfs:comment "The organisation holding the data subject to the access request."@en ;
              rdfs:label "Data Provider"@en .


###  https://w3id.org/orda#Decision
:Decision rdf:type owl:Class ;
          rdfs:subClassOf :ProcessActivity ;
          rdfs:comment "A formal decision taken by an authorised agent within a process phase. Modelled separately from documents to capture provenance, conditions, and revisability."@en ;
          rdfs:label "Decision"@en .


###  https://w3id.org/orda#DigitalServicesCoordinator
:DigitalServicesCoordinator rdf:type owl:Class ;
                            rdfs:subClassOf :RegulatoryAuthority ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty <https://w3id.org/dpv/owl#hasLegalBasis> ;
                                              owl:someValuesFrom <https://w3id.org/dpv/legal/eu#DSA>
                                            ] ;
                            owl:disjointWith :ResearchOrganisation ;
                            rdfs:comment "A Digital Services Coordinator as set out in Art. 49(2) DSA."@en ;
                            rdfs:label "Digital Services Coordinator"@en .


###  https://w3id.org/orda#DigitalServicesCoordinatorOfEstablishment
:DigitalServicesCoordinatorOfEstablishment rdf:type owl:Class ;
                                           rdfs:subClassOf :DigitalServicesCoordinator ;
                                           rdfs:comment "DSC-E: primary vetting body responsible for formulating the reasoned request."@en ;
                                           rdfs:label "DSC of Establishment"@en .


###  https://w3id.org/orda#DigitalServicesCoordinatorOfMemberState
:DigitalServicesCoordinatorOfMemberState rdf:type owl:Class ;
                                         rdfs:subClassOf :DigitalServicesCoordinator ;
                                         rdfs:comment "DSC-M: performs the completeness check on the application."@en ;
                                         rdfs:label "DSC of Member State"@en .


###  https://w3id.org/orda#DocumentStage
:DocumentStage rdf:type owl:Class ;
               rdfs:comment "A controlled vocabulary class for typing the procedural stage of a document. Instances are named individuals. Not all stages are valid for all document types — see allValuesFrom restrictions on each document class."@en ;
               rdfs:label "Document Stage"@en .


###  https://w3id.org/orda#EUDelegatedRegulation
:EUDelegatedRegulation rdf:type owl:Class ;
                       rdfs:subClassOf :EURegulation ;
                       rdfs:comment "Commission delegated regulations supplementing a parent EU regulation (typically linked with eli:based_on)."@en ;
                       rdfs:label "EU Delegated Regulation"@en .


###  https://w3id.org/orda#EUDirective
:EUDirective rdf:type owl:Class ;
             rdfs:subClassOf <http://data.europa.eu/eli/ontology#LegalResource> ,
                             <https://w3id.org/dpv/owl#LegalBasis> ;
             rdfs:comment "Grouping class for EU directives represented as eli:LegalResource individuals."@en ;
             rdfs:label "EU Directive"@en .


###  https://w3id.org/orda#EURegulation
:EURegulation rdf:type owl:Class ;
              rdfs:subClassOf <http://data.europa.eu/eli/ontology#LegalResource> ,
                              <https://w3id.org/dpv/owl#LegalBasis> ;
              rdfs:comment "Grouping class for EU regulations represented as eli:LegalResource individuals. Specific instrument kind uses eli:type_document with EU Publications Office resource-type concepts."@en ;
              rdfs:label "EU Regulation"@en .


###  https://w3id.org/orda#ElectoralProcessesRisk
:ElectoralProcessesRisk rdf:type owl:Class ;
                        rdfs:subClassOf :SystemicRiskCategory ;
                        rdfs:comment "Negative effects on electoral processes (Art. 34(1)(c))."@en ;
                        rdfs:label "Electoral Processes Risk"@en .


###  https://w3id.org/orda#ExpertConsultation
:ExpertConsultation rdf:type owl:Class ;
                    rdfs:subClassOf :ProcessActivity ;
                    rdfs:comment "Optional consultation with independent experts during assessment of an Art. 40(4) application (DA Art. 14)."@en ;
                    rdfs:label "Expert Consultation"@en .


###  https://w3id.org/orda#FundamentalRightsRisk
:FundamentalRightsRisk rdf:type owl:Class ;
                       rdfs:subClassOf :SystemicRiskCategory ;
                       rdfs:comment "Negative effects on the exercise of fundamental rights (Art. 34(1)(b))."@en ;
                       rdfs:label "Fundamental Rights Risk"@en .


###  https://w3id.org/orda#GenderBasedViolenceRisk
:GenderBasedViolenceRisk rdf:type owl:Class ;
                         rdfs:subClassOf :SystemicRiskCategory ;
                         rdfs:comment "Gender-based violence (Art. 34(1)(d))."@en ;
                         rdfs:label "Gender-based Violence Risk"@en .


###  https://w3id.org/orda#IllegalContentRisk
:IllegalContentRisk rdf:type owl:Class ;
                    rdfs:subClassOf :SystemicRiskCategory ;
                    rdfs:comment "Dissemination of illegal content (Art. 34(1)(a))."@en ;
                    rdfs:label "Illegal Content Risk"@en .


###  https://w3id.org/orda#InternalProcessesMitigation
:InternalProcessesMitigation rdf:type owl:Class ;
                             rdfs:subClassOf :MitigationMeasureCategory ;
                             rdfs:comment "Reinforcing the internal processes, resources, testing, documentation, or supervision of any of their activities in particular as regards detection of systemic risk."@en ;
                             rdfs:label "Internal processes mitigation"@en .


###  https://w3id.org/orda#LegalModality
:LegalModality rdf:type owl:Class ;
               rdfs:subClassOf :AccessModality ;
               rdfs:label "Legal Modality"@en .


###  https://w3id.org/orda#MediationConcluded
:MediationConcluded rdf:type owl:Class ;
                    rdfs:subClassOf :TriggerActivity ;
                    rdfs:comment "The mediator issues the result. Ends the Mediation Phase."@en ;
                    rdfs:label "Mediation Concluded"@en .


###  https://w3id.org/orda#MediationPhase
:MediationPhase rdf:type owl:Class ;
                rdfs:subClassOf :AuthorisationPhase ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty time:after ;
                                  owl:someValuesFrom :AmendmentPhase
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty <https://w3id.org/dpv/owl#hasLegalBasis> ;
                                  owl:someValuesFrom :DataAccessDelegatedRegulation
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :isTriggeredBy ;
                                  owl:someValuesFrom :MediationRequested
                                ] ;
                rdfs:comment "Mediation requested within max. 5 working days; conducted within max. 40 working days. Triggered by a :MediationRequested activity."@en ;
                rdfs:label "Mediation Phase"@en .


###  https://w3id.org/orda#MediationRequest
:MediationRequest rdf:type owl:Class ;
                  rdfs:subClassOf :ProcessDocument ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://w3id.org/dpv/owl#hasLegalBasis> ;
                                    owl:someValuesFrom :DataAccessDelegatedRegulation
                                  ] ;
                  rdfs:comment "Filed within max. 5 working days of triggering event."@en ;
                  rdfs:label "Request for Mediation"@en .


###  https://w3id.org/orda#MediationRequested
:MediationRequested rdf:type owl:Class ;
                    rdfs:subClassOf :TriggerActivity ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty <https://w3id.org/dpv/owl#hasLegalBasis> ;
                                      owl:someValuesFrom :DataAccessDelegatedRegulation
                                    ] ;
                    rdfs:comment "A party requests mediation within max. 5 working days. Triggers the Mediation Phase."@en ;
                    rdfs:label "Mediation Requested"@en .


###  https://w3id.org/orda#Mediator
:Mediator rdf:type owl:Class ;
          rdfs:subClassOf <https://w3id.org/cerif2/Person> ;
          rdfs:comment "An independent person conducting mediation between DSC-E and the data provider."@en ;
          rdfs:label "Mediator"@en .


###  https://w3id.org/orda#MethodologicalReview
:MethodologicalReview rdf:type owl:Class ;
                      rdfs:subClassOf :ExpertConsultation ;
                      rdfs:comment "Review of research methodology to ensure requested data is necessary and proportionate to stated objectives."@en ;
                      rdfs:label "Methodological Review"@en .


###  https://w3id.org/orda#MitigationMeasureCategory
:MitigationMeasureCategory rdf:type owl:Class ;
                           rdfs:comment "Flat taxonomy of risk mitigation measure types under DSA Article 35. In ABox data, use named individuals (e.g. :ServiceDesignMitigationCategory) with :assessesMitigationMeasureCategory; enforced by ORDA.shacl.ttl."@en ;
                           rdfs:label "Mitigation Measure Category"@en ;
                           rdfs:seeAlso <http://data.europa.eu/eli/reg/2022/2065/oj> .


###  https://w3id.org/orda#NationalDataProtectionAuthority
:NationalDataProtectionAuthority rdf:type owl:Class ;
                                 rdfs:subClassOf :DataProtectionAuthority ;
                                 rdfs:comment "A member-state data protection authority (GDPR Art. 51)."@en ;
                                 rdfs:label "National Data Protection Authority"@en .


###  https://w3id.org/orda#OrganisationalModality
:OrganisationalModality rdf:type owl:Class ;
                        rdfs:subClassOf :AccessModality ;
                        rdfs:label "Organisational Modality"@en .


###  https://w3id.org/orda#PhysicalMentalWellbeingRisk
:PhysicalMentalWellbeingRisk rdf:type owl:Class ;
                             rdfs:subClassOf :SystemicRiskCategory ;
                             rdfs:comment "Serious negative consequences to a person's physical and mental well-being (Art. 34(1)(d))."@en ;
                             rdfs:label "Physical and Mental Well-being Risk"@en .


###  https://w3id.org/orda#PlatformVettingPhase
:PlatformVettingPhase rdf:type owl:Class ;
                      rdfs:subClassOf time:Interval ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty <https://w3id.org/dpv/owl#hasLegalBasis> ;
                                        owl:someValuesFrom <https://w3id.org/dpv/legal/eu#DSA>
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty :occursInProcess ;
                                        owl:someValuesFrom :Art40_12_DataAccessProcess
                                      ] ;
                      rdfs:comment "Period in which the VLOP or VLOSE assesses an Art. 40(12) public-data request. No DSC vetting or reasoned request under the Delegated Act."@en ;
                      rdfs:label "Platform Vetting Phase"@en .


###  https://w3id.org/orda#PrincipalResearcher
:PrincipalResearcher rdf:type owl:Class ;
                     rdfs:subClassOf :RequestingResearcher ;
                     rdfs:comment "The lead researcher responsible for submitting and managing the data access application."@en ;
                     rdfs:label "Principal Researcher"@en .


###  https://w3id.org/orda#ProcessActivity
:ProcessActivity rdf:type owl:Class ;
                 rdfs:subClassOf prov:Activity ;
                 rdfs:comment "Any action in the data access process, including phase triggers, decisions, consultations, and communications."@en ;
                 rdfs:label "Process Activity"@en .


###  https://w3id.org/orda#ProcessDocument
:ProcessDocument rdf:type owl:Class ;
                 rdfs:subClassOf prov:Entity ;
                 rdfs:comment "A document in the DSA data access procedure (applications, reasoned requests, amendments). Distinct from cerif:Document research outputs; use prov:wasRevisionOf for version chains."@en ;
                 rdfs:label "Process Document"@en .


###  https://w3id.org/orda#ProviderCooperationMitigation
:ProviderCooperationMitigation rdf:type owl:Class ;
                               rdfs:subClassOf :MitigationMeasureCategory ;
                               rdfs:comment "Initiating or adjusting cooperation with other providers of online platforms or of online search engines through the codes of conduct and the crisis protocols referred to in Articles 45 and 48 respectively."@en ;
                               rdfs:label "Provider cooperation mitigation"@en .


###  https://w3id.org/orda#PublicHealthRisk
:PublicHealthRisk rdf:type owl:Class ;
                  rdfs:subClassOf :SystemicRiskCategory ;
                  rdfs:comment "Public health (Art. 34(1)(d))."@en ;
                  rdfs:label "Public Health Risk"@en .


###  https://w3id.org/orda#PublicSecurityRisk
:PublicSecurityRisk rdf:type owl:Class ;
                    rdfs:subClassOf :SystemicRiskCategory ;
                    rdfs:comment "Negative effects on public security (Art. 34(1)(c))."@en ;
                    rdfs:label "Public Security Risk"@en .


###  https://w3id.org/orda#ReasonedRequest
:ReasonedRequest rdf:type owl:Class ;
                 rdfs:subClassOf :ProcessDocument ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty <https://w3id.org/dpv/owl#hasLegalBasis> ;
                                   owl:someValuesFrom <https://w3id.org/dpv/legal/eu#DSA>
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty <https://w3id.org/dpv/owl#hasLegalBasis> ;
                                   owl:someValuesFrom :DataAccessDelegatedRegulation
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :formulatedBy ;
                                   owl:someValuesFrom :DigitalServicesCoordinatorOfEstablishment
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :documentStage ;
                                   owl:allValuesFrom [ rdf:type owl:Class ;
                                                       owl:oneOf ( :StageAmended
                                                                   :StageInitial
                                                                   :StageMediated
                                                                 )
                                                     ]
                                 ] ;
                 rdfs:comment "Issued by DSC-E following vetting. Use :documentStage for procedural status and prov:wasRevisionOf to link amended or mediated versions."@en ;
                 rdfs:label "Reasoned Request"@en ;
                 rdfs:seeAlso <http://data.europa.eu/eli/reg_del/2025/2050/oj> .


###  https://w3id.org/orda#ReasonedRequestIssued
:ReasonedRequestIssued rdf:type owl:Class ;
                       rdfs:subClassOf :TriggerActivity ;
                       rdfs:comment "DSC-E issues the initial reasoned request. Triggers the Amendment Phase."@en ;
                       rdfs:label "Reasoned Request Issued"@en .


###  https://w3id.org/orda#RegulatoryAuthority
:RegulatoryAuthority rdf:type owl:Class ;
                     rdfs:subClassOf <https://w3id.org/cerif2/Organisation_Unit> ;
                     rdfs:comment "Public authority with supervisory or coordination functions relevant to DSA Art. 40 (DSCs, data protection authorities, European Commission)."@en ;
                     rdfs:label "Regulatory Authority"@en .


###  https://w3id.org/orda#RequestingResearcher
:RequestingResearcher rdf:type owl:Class ;
                      rdfs:subClassOf :Researcher ;
                      rdfs:comment "A researcher who has initiated or is party to a data access request."@en ;
                      rdfs:label "Requesting Researcher"@en .


###  https://w3id.org/orda#ResearchActivity
:ResearchActivity rdf:type owl:Class ;
                  rdfs:comment "Actions taken with accessed data (analysis, modelling, comparison, etc.)."@en ;
                  rdfs:label "Research Activity"@en .


###  https://w3id.org/orda#ResearchDataOutput
:ResearchDataOutput rdf:type owl:Class ;
                    rdfs:subClassOf <http://www.w3.org/ns/dcat#Dataset> ,
                                    <https://w3id.org/cerif2/Resource> ,
                                    :ResearchOutput ;
                    rdfs:comment "A dataset released as a project output. Use cerifres:hasIdentifier (e.g. DOI) and DCAT properties for distribution details."@en ;
                    rdfs:label "Research Data Output"@en .


###  https://w3id.org/orda#ResearchMethod
:ResearchMethod rdf:type owl:Class ;
                rdfs:label "Research Method"@en .


###  https://w3id.org/orda#ResearchOrganisation
:ResearchOrganisation rdf:type owl:Class ;
                      rdfs:subClassOf <https://w3id.org/cerif2/Organisation_Unit> ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty <https://w3id.org/dpv/owl#hasLegalBasis> ;
                                        owl:someValuesFrom :CDSMDirective
                                      ] ;
                      rdfs:comment "A research organisation as defined in Article 2, point (1), of Directive (EU) 2019/790 (Copyright in the Digital Single Market). Researchers access platform data in an institutional capacity; distinct from :DataProvider (VLOP/VLOSE), :DigitalServicesCoordinator, and :DataProtectionAuthority."@en ;
                      rdfs:label "Research Organisation"@en ;
                      rdfs:seeAlso <http://data.europa.eu/eli/dir/2019/790/oj> .


###  https://w3id.org/orda#ResearchOutput
:ResearchOutput rdf:type owl:Class ;
                rdfs:comment "A research result produced by a :ResearchProject. Superclass for CERIF documents and dataset resources."@en ;
                rdfs:label "Research Output"@en .


###  https://w3id.org/orda#ResearchProject
:ResearchProject rdf:type owl:Class ;
                 rdfs:subClassOf <https://w3id.org/cerif2/Project> ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty <https://w3id.org/dpv/owl#hasLegalBasis> ;
                                   owl:someValuesFrom <https://w3id.org/dpv/legal/eu#DSA>
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :hasDataProvider ;
                                   owl:someValuesFrom :DataProvider
                                 ] ;
                 rdfs:comment "A CERIF research project with contributors (:hasContribution), funding (cerifprj:fundedBy), schedule (:hasDateRange), outputs (:hasResearchOutput), name (cerifprj:name), description (dcterms:description), data providers, methodology, and Art. 34/35 categories. May have multiple :hasDataAccessProcess values."@en ;
                 rdfs:label "Research Project"@en .


###  https://w3id.org/orda#ResearchPublication
:ResearchPublication rdf:type owl:Class ;
                     rdfs:subClassOf <https://w3id.org/cerif2/Document> ,
                                     :ResearchOutput ;
                     rdfs:comment "A scholarly publication (article, preprint, book chapter) modelled as cerif:Document with optional cerif:Document_Publication metadata."@en ;
                     rdfs:label "Research Publication"@en .


###  https://w3id.org/orda#ResearchQuestion
:ResearchQuestion rdf:type owl:Class ;
                  rdfs:label "Research Question"@en .


###  https://w3id.org/orda#ResearchReport
:ResearchReport rdf:type owl:Class ;
                rdfs:subClassOf <https://w3id.org/cerif2/Document> ,
                                :ResearchOutput ;
                rdfs:comment "A technical or project report released as a CERIF document."@en ;
                rdfs:label "Research Report"@en .


###  https://w3id.org/orda#ResearchTopic
:ResearchTopic rdf:type owl:Class ;
               rdfs:label "Research Topic"@en .


###  https://w3id.org/orda#Researcher
:Researcher rdf:type owl:Class ;
            rdfs:subClassOf <https://w3id.org/cerif2/Person> ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :hasContact ;
                              owl:someValuesFrom <https://w3id.org/cerif2/Postal_Address>
                            ] ;
            rdfs:comment "A researcher modelled as cerif:Person with :hasPersonName, :hasContact (postal and/or electronic), and optional :hasAffiliationStatement."@en ;
            rdfs:label "Researcher"@en ;
            rdfs:seeAlso <https://w3id.org/cerif2/Person> .


###  https://w3id.org/orda#RiskToMinors
:RiskToMinors rdf:type owl:Class ;
              rdfs:subClassOf :SystemicRiskCategory ;
              rdfs:comment "Protection of minors (Art. 34(1)(d))."@en ;
              rdfs:label "Risk to Minors"@en .


###  https://w3id.org/orda#ServiceDesignMitigation
:ServiceDesignMitigation rdf:type owl:Class ;
                         rdfs:subClassOf :MitigationMeasureCategory ;
                         rdfs:comment "Adapting the design, features or functioning of their services, including their online interfaces."@en ;
                         rdfs:label "Service design mitigation"@en .


###  https://w3id.org/orda#SyntheticMediaMarkingMitigation
:SyntheticMediaMarkingMitigation rdf:type owl:Class ;
                                 rdfs:subClassOf :MitigationMeasureCategory ;
                                 rdfs:comment "Ensuring that an item of information, whether it constitutes a generated or manipulated image, audio or video that appreciably resembles existing persons, objects, places or other entities or events and falsely appears to a person to be authentic or truthful is distinguishable through prominent markings when presented on their online interfaces, and, in addition, providing an easy to use functionality which enables recipients of the service to indicate such information."@en ;
                                 rdfs:label "Synthetic media marking mitigation"@en .


###  https://w3id.org/orda#SystemicRiskCategory
:SystemicRiskCategory rdf:type owl:Class ;
                      rdfs:comment "Flat taxonomy of systemic risk types under DSA Article 34(1). Distinct from dpv:Risk (data-processing risks). In ABox data, link projects to named individuals (e.g. :CivicDiscourseRiskCategory) via :addressesSystemicRiskCategory; enforced by ORDA.shacl.ttl."@en ;
                      rdfs:label "Systemic Risk Category"@en ;
                      rdfs:seeAlso <http://data.europa.eu/eli/reg/2022/2065/oj> .


###  https://w3id.org/orda#TechnicalModality
:TechnicalModality rdf:type owl:Class ;
                   rdfs:subClassOf :AccessModality ;
                   rdfs:comment "Technical controls — APIs, scraping, secure enclaves, pseudonymisation, query-only access."@en ;
                   rdfs:label "Technical Modality"@en .


###  https://w3id.org/orda#TermsAndConditionsMitigation
:TermsAndConditionsMitigation rdf:type owl:Class ;
                              rdfs:subClassOf :MitigationMeasureCategory ;
                              rdfs:comment "Adapting their terms and conditions and their enforcement."@en ;
                              rdfs:label "Terms and conditions mitigation"@en .


###  https://w3id.org/orda#TriggerActivity
:TriggerActivity rdf:type owl:Class ;
                 rdfs:subClassOf :ProcessActivity ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :hasStartInstant ;
                                   owl:someValuesFrom time:Instant
                                 ] ;
                 rdfs:comment "A provenance activity that marks the start (or other key point) of a process phase. Must be linked to a start instant via :hasStartInstant; use time:inXSDDateTimeStamp on that instant for the timestamp."@en ;
                 rdfs:label "Trigger Activity"@en .


###  https://w3id.org/orda#TrustedFlaggerCooperationMitigation
:TrustedFlaggerCooperationMitigation rdf:type owl:Class ;
                                     rdfs:subClassOf :MitigationMeasureCategory ;
                                     rdfs:comment "Initiating or adjusting cooperation with trusted flaggers in accordance with Article 22 and the implementation of the decisions of out-of-court dispute settlement bodies pursuant to Article 21."@en ;
                                     rdfs:label "Trusted flagger cooperation mitigation"@en .


###  https://w3id.org/orda#VeryLargeOnlinePlatform
:VeryLargeOnlinePlatform rdf:type owl:Class ;
                         rdfs:subClassOf :DataProvider ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty <https://w3id.org/dpv/owl#hasLegalBasis> ;
                                           owl:someValuesFrom <https://w3id.org/dpv/legal/eu#DSA>
                                         ] ;
                         rdfs:comment "Designated online platforms with equal to or more than 45 million average monthly active recipients of the service in the Union."@en ;
                         rdfs:label "Very Large Online Platform"@en .


###  https://w3id.org/orda#VeryLargeOnlineSearchEngine
:VeryLargeOnlineSearchEngine rdf:type owl:Class ;
                             rdfs:subClassOf :DataProvider ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty <https://w3id.org/dpv/owl#hasLegalBasis> ;
                                               owl:someValuesFrom <https://w3id.org/dpv/legal/eu#DSA>
                                             ] ;
                             rdfs:comment "Designated online search engines with equal to or more than 45 million average monthly active recipients of the service in the Union."@en ;
                             rdfs:label "Very Large Online Search Engine"@en .


###  https://w3id.org/orda#VettedResearcher
:VettedResearcher rdf:type owl:Class ;
                  rdfs:subClassOf :Researcher ;
                  rdfs:comment "A researcher vetted under DSA Art. 40(8) for Art. 40(4) non-public data access. Must have a cerif:Affiliation_Statement via :hasAffiliationStatement whose cerifaff:hasInstitution is a :ResearchOrganisation (CDSM Art. 2(1))."@en ;
                  rdfs:label "Vetted Researcher"@en .


###  https://w3id.org/orda#VettingPhase
:VettingPhase rdf:type owl:Class ;
              rdfs:subClassOf :AuthorisationPhase ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty time:after ;
                                owl:someValuesFrom :CompletenessCheckPhase
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty <https://w3id.org/dpv/owl#hasLegalBasis> ;
                                owl:someValuesFrom <https://w3id.org/dpv/legal/eu#DSA>
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty <https://w3id.org/dpv/owl#hasLegalBasis> ;
                                owl:someValuesFrom :DataAccessDelegatedRegulation
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :isTriggeredBy ;
                                owl:someValuesFrom :CompletenessCheckPassed
                              ] ;
              rdfs:comment "DSC-E formulates and issues the initial reasoned request. Max. 80 working days. Triggered by a :CompletenessCheckPassed activity."@en ;
              rdfs:label "Vetting Phase"@en .


#################################################################
#    Individuals
#################################################################

###  http://publications.europa.eu/resource/authority/file-type/CSV
<http://publications.europa.eu/resource/authority/file-type/CSV> rdf:type owl:NamedIndividual .


###  http://publications.europa.eu/resource/authority/resource-type/DIR
<http://publications.europa.eu/resource/authority/resource-type/DIR> rdf:type owl:NamedIndividual .


###  http://publications.europa.eu/resource/authority/resource-type/REG
<http://publications.europa.eu/resource/authority/resource-type/REG> rdf:type owl:NamedIndividual .


###  http://publications.europa.eu/resource/authority/resource-type/REG_DEL
<http://publications.europa.eu/resource/authority/resource-type/REG_DEL> rdf:type owl:NamedIndividual .


###  https://w3id.org/dpv/legal/eu#DSA
<https://w3id.org/dpv/legal/eu#DSA> rdf:type owl:NamedIndividual ,
                                             <http://data.europa.eu/eli/ontology#LegalResource> ,
                                             <https://w3id.org/dpv/owl#LegalBasis> ,
                                             :EURegulation ;
                                    <http://data.europa.eu/eli/ontology#type_document> <http://publications.europa.eu/resource/authority/resource-type/REG> .


###  https://w3id.org/orda#AdvertisingSystemsMitigationCategory
:AdvertisingSystemsMitigationCategory rdf:type owl:NamedIndividual ,
                                               :AdvertisingSystemsMitigation ;
                                      <https://w3id.org/dpv/owl#hasLegalBasis> :LegalBasis_DSA_35_e ;
                                      rdfs:label "Advertising systems"@en .


###  https://w3id.org/orda#AlgorithmicSystemsMitigationCategory
:AlgorithmicSystemsMitigationCategory rdf:type owl:NamedIndividual ,
                                               :AlgorithmicSystemsMitigation ;
                                      <https://w3id.org/dpv/owl#hasLegalBasis> :LegalBasis_DSA_35_d ;
                                      rdfs:label "Algorithmic systems"@en .


###  https://w3id.org/orda#AmendmentPhaseInstance
:AmendmentPhaseInstance rdf:type owl:NamedIndividual ,
                                 :AmendmentPhase ;
                        :maxWorkingDays 15 ;
                        rdfs:label "Amendment Phase (statutory limit)"@en .


###  https://w3id.org/orda#AwarenessRaisingMitigationCategory
:AwarenessRaisingMitigationCategory rdf:type owl:NamedIndividual ,
                                             :AwarenessRaisingMitigation ;
                                    <https://w3id.org/dpv/owl#hasLegalBasis> :LegalBasis_DSA_35_i ;
                                    rdfs:label "Awareness raising"@en .


###  https://w3id.org/orda#CDSMDirective
:CDSMDirective rdf:type owl:NamedIndividual ,
                        <http://data.europa.eu/eli/ontology#LegalResource> ,
                        <https://w3id.org/dpv/owl#LegalBasis> ,
                        :EUDirective ;
               <http://data.europa.eu/eli/ontology#type_document> <http://publications.europa.eu/resource/authority/resource-type/DIR> .


###  https://w3id.org/orda#ChildProtectionMitigationCategory
:ChildProtectionMitigationCategory rdf:type owl:NamedIndividual ,
                                            :ChildProtectionMitigation ;
                                   <https://w3id.org/dpv/owl#hasLegalBasis> :LegalBasis_DSA_35_j ;
                                   rdfs:label "Child protection"@en .


###  https://w3id.org/orda#CivicDiscourseRiskCategory
:CivicDiscourseRiskCategory rdf:type owl:NamedIndividual ,
