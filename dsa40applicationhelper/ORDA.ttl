@prefix : <https://w3id.org/orda#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@base <https://w3id.org/orda#> .

<https://w3id.org/orda> rdf:type owl:Ontology ;
                         owl:imports <http://www.w3.org/2006/time> ,
                                     <http://www.w3.org/ns/prov-o#> ;
                         dcterms:description "Models DSA Art. 40 data access (ORDA + OWL Time + PROV), CERIF Core 2 research metadata, and DQV quality annotations on platform data (DCAT distributions). Procedural phases use time:Interval; CRIS-facing project description uses cerif:Project, cerif:Person, cerif:Organisation_Unit, cerif:Funding, cerif:Document. See ORDA.md and ORDA.shacl.ttl."@en ;
                         dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
                         dcterms:title "ORDA — Ontology for Research Data Access"@en ;
                         rdfs:seeAlso <http://www.w3.org/ns/csvw#> ,
                                      <http://www.w3.org/ns/dcat#> ,
                                      <http://www.w3.org/ns/dqv#> ,
                                      <http://www.w3.org/ns/odrl/2/> ,
                                      <https://w3id.org/cerif2/> ,
                                      <https://w3id.org/dpv/owl#> ,
                                      <https://w3id.org/orda/shapes> ;
                         owl:versionInfo "0.8.0"@en .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/description
dcterms:description rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
dcterms:license rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
dcterms:title rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/prov#wasRevisionOf
prov:wasRevisionOf rdf:type owl:AnnotationProperty ;
                   rdfs:range prov:Entity .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


###  https://w3id.org/cerif2/DOI_ID
<https://w3id.org/cerif2/DOI_ID> rdf:type rdfs:Datatype ;
                                 rdfs:isDefinedBy <https://w3id.org/cerif2/> .


###  https://w3id.org/cerif2/Date
<https://w3id.org/cerif2/Date> rdf:type rdfs:Datatype ;
                               rdfs:isDefinedBy <https://w3id.org/cerif2/> ;
                               owl:equivalentClass xsd:date .


###  https://w3id.org/cerif2/Multilingual_String
<https://w3id.org/cerif2/Multilingual_String> rdf:type rdfs:Datatype ;
                                              rdfs:isDefinedBy <https://w3id.org/cerif2/> .


###  https://w3id.org/cerif2/ORCID_iD
<https://w3id.org/cerif2/ORCID_iD> rdf:type rdfs:Datatype ;
                                   rdfs:isDefinedBy <https://w3id.org/cerif2/> .


###  https://w3id.org/cerif2/ROR_ID
<https://w3id.org/cerif2/ROR_ID> rdf:type rdfs:Datatype ;
                                 rdfs:isDefinedBy <https://w3id.org/cerif2/> .


#################################################################
#    Object Properties
#################################################################

###  http://data.europa.eu/eli/ontology#based_on
<http://data.europa.eu/eli/ontology#based_on> rdf:type owl:ObjectProperty ;
                                              rdfs:domain <http://data.europa.eu/eli/ontology#LegalResource> ;
                                              rdfs:range <http://data.europa.eu/eli/ontology#LegalResource> ;
                                              rdfs:comment "Legal basis link between acts (e.g. delegated regulation supplementing a parent regulation)."@en ;
                                              rdfs:isDefinedBy <http://data.europa.eu/eli/ontology> ;
                                              rdfs:label "based on"@en .


###  http://data.europa.eu/eli/ontology#is_part_of
<http://data.europa.eu/eli/ontology#is_part_of> rdf:type owl:ObjectProperty ;
                                                rdfs:domain <http://data.europa.eu/eli/ontology#LegalResource> ;
                                                rdfs:range <http://data.europa.eu/eli/ontology#LegalResource> ;
                                                rdfs:isDefinedBy <http://data.europa.eu/eli/ontology> ;
                                                rdfs:label "is part of"@en .


###  http://data.europa.eu/eli/ontology#type_document
<http://data.europa.eu/eli/ontology#type_document> rdf:type owl:ObjectProperty ;
                                                   rdfs:domain <http://data.europa.eu/eli/ontology#LegalResource> ;
                                                   rdfs:isDefinedBy <http://data.europa.eu/eli/ontology> ;
                                                   rdfs:label "type of document"@en ;
                                                   rdfs:seeAlso <https://op.europa.eu/en/web/eu-vocabularies/at-dataset/-/resource/dataset/resource-type> .


###  http://purl.org/dc/terms/format
dcterms:format rdf:type owl:ObjectProperty ;
               rdfs:domain <http://www.w3.org/ns/dcat#Distribution> ;
               rdfs:range dcterms:MediaTypeOrExtent ;
               rdfs:isDefinedBy dcterms: ;
               rdfs:label "format"@en .


###  http://purl.org/dc/terms/hasFormat
dcterms:hasFormat rdf:type owl:ObjectProperty ;
                  rdfs:domain <http://www.w3.org/ns/dcat#Distribution> ;
                  rdfs:comment "Links a dcat:Distribution to a machine-readable schema description (csvw:Schema for CSV, cerif:Document for OpenAPI/JSON Schema)."@en ;
                  rdfs:isDefinedBy dcterms: ;
                  rdfs:label "has format"@en .


###  http://www.w3.org/2006/time#after
time:after rdf:type owl:ObjectProperty .


###  http://www.w3.org/2006/time#hasBeginning
time:hasBeginning rdf:type owl:ObjectProperty ;
                  rdfs:domain time:Interval ;
                  rdfs:range time:Instant .


###  http://www.w3.org/2006/time#hasEnd
time:hasEnd rdf:type owl:ObjectProperty ;
            rdfs:domain time:Interval ;
            rdfs:range time:Instant .


###  http://www.w3.org/ns/csvw#column
<http://www.w3.org/ns/csvw#column> rdf:type owl:ObjectProperty ;
                                   rdfs:domain <http://www.w3.org/ns/csvw#Schema> ;
                                   rdfs:range <http://www.w3.org/ns/csvw#Column> ;
                                   rdfs:isDefinedBy <http://www.w3.org/ns/csvw#> ;
                                   rdfs:label "column"@en .


###  http://www.w3.org/ns/prov#used
prov:used rdf:type owl:ObjectProperty ;
          rdfs:domain prov:Activity ;
          rdfs:range prov:Entity ;
          rdfs:comment "An activity consumed or built upon a prior entity (e.g. a draft application revised into a submitted one)."@en ;
          rdfs:label "used"@en .


###  http://www.w3.org/ns/prov#wasAssociatedWith
prov:wasAssociatedWith rdf:type owl:ObjectProperty .


###  http://www.w3.org/ns/prov#wasDerivedFrom
prov:wasDerivedFrom rdf:type owl:ObjectProperty ;
                    rdfs:domain prov:Entity ;
                    rdfs:range prov:Entity ;
                    rdfs:comment "A weaker derivation link between entities when wasRevisionOf is too strict."@en ;
                    rdfs:label "was derived from"@en .


###  http://www.w3.org/ns/prov#wasGeneratedBy
prov:wasGeneratedBy rdf:type owl:ObjectProperty ;
                    owl:inverseOf :produces ;
                    rdfs:domain prov:Entity ;
                    rdfs:range prov:Activity .


###  http://www.w3.org/ns/prov#wasInformedBy
prov:wasInformedBy rdf:type owl:ObjectProperty ;
                   rdfs:domain prov:Activity ;
                   rdfs:range prov:Activity ;
                   rdfs:comment "One activity followed or depended on another in the process."@en ;
                   rdfs:label "was informed by"@en .


###  http://www.w3.org/ns/prov#wasRevisionOf
prov:wasRevisionOf rdf:type owl:ObjectProperty ;
                   rdfs:domain prov:Entity .


###  https://w3id.org/cerif2/Acknowledgement_Statement#testify
<https://w3id.org/cerif2/Acknowledgement_Statement#testify> rdf:type owl:ObjectProperty ;
                                                            rdfs:isDefinedBy <https://w3id.org/cerif2/> ;
                                                            rdfs:label "testify"@en .


###  https://w3id.org/cerif2/Activity#hasActor
<https://w3id.org/cerif2/Activity#hasActor> rdf:type owl:ObjectProperty ;
                                            rdfs:range <https://w3id.org/cerif2/Agent> ;
                                            rdfs:isDefinedBy <https://w3id.org/cerif2/> ;
                                            rdfs:label "has actor"@en .


###  https://w3id.org/cerif2/Affiliation_Statement#hasInstitution
<https://w3id.org/cerif2/Affiliation_Statement#hasInstitution> rdf:type owl:ObjectProperty ;
                                                               rdfs:range <https://w3id.org/cerif2/Organisation_Unit> ;
                                                               rdfs:isDefinedBy <https://w3id.org/cerif2/> ;
                                                               rdfs:label "has institution"@en .


###  https://w3id.org/cerif2/Affiliation_Statement#hasPerson
<https://w3id.org/cerif2/Affiliation_Statement#hasPerson> rdf:type owl:ObjectProperty ;
                                                          owl:inverseOf <https://w3id.org/cerif2/Person#isThePersonIn> ;
                                                          rdfs:range <https://w3id.org/cerif2/Person> ;
                                                          rdfs:isDefinedBy <https://w3id.org/cerif2/> ;
                                                          rdfs:label "has person"@en .


###  https://w3id.org/cerif2/Agent#hasIdentifier
<https://w3id.org/cerif2/Agent#hasIdentifier> rdf:type owl:ObjectProperty ;
                                              rdfs:domain <https://w3id.org/cerif2/Agent> ;
                                              rdfs:range <https://w3id.org/cerif2/Agent_Identifier> ;
                                              rdfs:isDefinedBy <https://w3id.org/cerif2/> ;
                                              rdfs:label "has identifier"@en .


###  https://w3id.org/cerif2/Contribution_to_Document#hasTarget
<https://w3id.org/cerif2/Contribution_to_Document#hasTarget> rdf:type owl:ObjectProperty ;
                                                             rdfs:range <https://w3id.org/cerif2/Document> ;
                                                             rdfs:isDefinedBy <https://w3id.org/cerif2/> ;
                                                             rdfs:label "has target"@en .


###  https://w3id.org/cerif2/Contribution_to_Project#hasTarget
<https://w3id.org/cerif2/Contribution_to_Project#hasTarget> rdf:type owl:ObjectProperty ;
                                                            owl:inverseOf <https://w3id.org/cerif2/Project#hasContribution> ;
                                                            rdfs:range <https://w3id.org/cerif2/Project> ;
                                                            rdfs:isDefinedBy <https://w3id.org/cerif2/> ;
                                                            rdfs:label "has target"@en .


###  https://w3id.org/cerif2/Document#hasContribution
<https://w3id.org/cerif2/Document#hasContribution> rdf:type owl:ObjectProperty ;
                                                   rdfs:domain <https://w3id.org/cerif2/Document> ;
                                                   rdfs:isDefinedBy <https://w3id.org/cerif2/> ;
                                                   rdfs:label "has contribution"@en .


###  https://w3id.org/cerif2/Document#publishedAs
<https://w3id.org/cerif2/Document#publishedAs> rdf:type owl:ObjectProperty ;
                                               rdfs:domain <https://w3id.org/cerif2/Document> ;
                                               rdfs:range <https://w3id.org/cerif2/Document_Publication> ;
                                               rdfs:isDefinedBy <https://w3id.org/cerif2/> ;
                                               rdfs:label "published as"@en .


###  https://w3id.org/cerif2/Funding#covers
<https://w3id.org/cerif2/Funding#covers> rdf:type owl:ObjectProperty ;
                                         owl:inverseOf <https://w3id.org/cerif2/Project#fundedBy> ;
                                         rdfs:domain <https://w3id.org/cerif2/Funding> ;
                                         rdfs:range <https://w3id.org/cerif2/Project> ;
                                         rdfs:isDefinedBy <https://w3id.org/cerif2/> ;
                                         rdfs:label "covers"@en .


###  https://w3id.org/cerif2/Person#isThePersonIn
<https://w3id.org/cerif2/Person#isThePersonIn> rdf:type owl:ObjectProperty ;
                                               rdfs:domain <https://w3id.org/cerif2/Person> ;
                                               rdfs:isDefinedBy <https://w3id.org/cerif2/> ;
                                               rdfs:label "is the person in"@en .


###  https://w3id.org/cerif2/Project#fundedBy
<https://w3id.org/cerif2/Project#fundedBy> rdf:type owl:ObjectProperty ;
                                           rdfs:domain :ResearchProject ;
                                           rdfs:range <https://w3id.org/cerif2/Funding> ;
                                           rdfs:isDefinedBy <https://w3id.org/cerif2/> ;
                                           rdfs:label "funded by"@en .


###  https://w3id.org/cerif2/Project#hasContribution
<https://w3id.org/cerif2/Project#hasContribution> rdf:type owl:ObjectProperty ;
                                                  rdfs:domain <https://w3id.org/cerif2/Project> ;
                                                  rdfs:isDefinedBy <https://w3id.org/cerif2/> ;
                                                  rdfs:label "has contribution"@en .


###  https://w3id.org/cerif2/Resource#hasDescription
<https://w3id.org/cerif2/Resource#hasDescription> rdf:type owl:ObjectProperty ;
                                                  rdfs:domain <https://w3id.org/cerif2/Resource> ;
                                                  rdfs:range <https://w3id.org/cerif2/Document> ;
                                                  rdfs:isDefinedBy <https://w3id.org/cerif2/> ;
                                                  rdfs:label "has description"@en .


###  https://w3id.org/cerif2/Resource#hasIdentifier
<https://w3id.org/cerif2/Resource#hasIdentifier> rdf:type owl:ObjectProperty ;
                                                 rdfs:domain <https://w3id.org/cerif2/Resource> ;
                                                 rdfs:range <https://w3id.org/cerif2/Resource_Identifier> ;
                                                 rdfs:isDefinedBy <https://w3id.org/cerif2/> ;
                                                 rdfs:label "has identifier"@en .


###  https://w3id.org/dpv/owl#hasLegalBasis
<https://w3id.org/dpv/owl#hasLegalBasis> rdf:type owl:ObjectProperty ;
                                         rdfs:domain [ rdf:type owl:Class ;
                                                       owl:unionOf ( :DataAccessProcess
                                                                     :DataAccessRequest
                                                                     :ResearchOrganisation
                                                                     :ResearchProject
                                                                   )
                                                     ] ;
                                         rdfs:range <https://w3id.org/dpv/owl#LegalBasis> ;
                                         rdfs:comment "Links an entity to the legal act or provision that authorises or defines it (DPV pattern). Used for projects, processes, and taxonomy categories."@en .


###  https://w3id.org/orda#addressesSystemicRiskCategory
:addressesSystemicRiskCategory rdf:type owl:ObjectProperty ;
                               rdfs:domain :ResearchProject ;
                               rdfs:range :SystemicRiskCategory ;
                               rdfs:comment "Links a research project to one or more DSA Art. 34(1) systemic risk categories. Use named vocabulary individuals (e.g. :IllegalContentRiskCategory). Validated by ORDA.shacl.ttl."@en ;
                               rdfs:label "addresses systemic risk category"@en .


###  https://w3id.org/orda#amendmentRequestedBy
:amendmentRequestedBy rdf:type owl:ObjectProperty ;
                      rdfs:domain :AmendmentRequest ;
                      rdfs:range :DataProvider ;
                      rdfs:label "amendment requested by"@en .


###  https://w3id.org/orda#amendsRequest
:amendsRequest rdf:type owl:ObjectProperty ;
               rdfs:domain :AmendmentRequest ;
               rdfs:range :ReasonedRequest ;
               rdfs:label "amends request"@en .


###  https://w3id.org/orda#assessedBy
:assessedBy rdf:type owl:ObjectProperty ;
            rdfs:domain :Art40_4_DataAccessRequest ;
            rdfs:range :DigitalServicesCoordinatorOfEstablishment ;
            rdfs:comment "DSC-E: final vetting and reasoned request formulation."@en ;
            rdfs:label "assessed by"@en .


###  https://w3id.org/orda#assessesMitigationMeasureCategory
:assessesMitigationMeasureCategory rdf:type owl:ObjectProperty ;
                                   rdfs:domain :ResearchProject ;
                                   rdfs:range :MitigationMeasureCategory ;
                                   rdfs:comment "Links a research project to mitigation measure categories assessed under Art. 40(4). Use named vocabulary individuals (e.g. :ServiceDesignMitigationCategory). Validated by ORDA.shacl.ttl."@en ;
                                   rdfs:label "assesses mitigation measure category"@en .


###  https://w3id.org/orda#assessesMitigationMeasures
:assessesMitigationMeasures rdf:type owl:ObjectProperty ;
                            rdfs:domain :ResearchProject ;
                            rdfs:range :DataProvider ;
                            rdfs:comment "The VLOP or VLOSE whose risk mitigation measures under DSA Art. 35 the project assesses for adequacy, efficiency and impact (Art. 40(4) purpose)."@en ;
                            rdfs:label "assesses mitigation measures"@en .


###  https://w3id.org/orda#communicationBetween
:communicationBetween rdf:type owl:ObjectProperty ;
                      rdfs:domain :CommunicationEvent ;
                      rdfs:range <https://w3id.org/cerif2/Agent> ;
                      rdfs:label "communication between"@en .


###  https://w3id.org/orda#concerns
:concerns rdf:type owl:ObjectProperty ;
          rdfs:comment "Links a document or action to the dataset or resource it pertains to."@en ;
          rdfs:label "concerns"@en .


###  https://w3id.org/orda#consultationConductedWith
:consultationConductedWith rdf:type owl:ObjectProperty ;
                           rdfs:domain :DataProtectionConsultation ;
                           rdfs:range :DataProtectionAuthority ;
                           rdfs:comment "The data protection authority involved in a consultation on GDPR or LED aspects of an application."@en ;
                           rdfs:label "consultation conducted with"@en .


###  https://w3id.org/orda#consultationRequestedBy
:consultationRequestedBy rdf:type owl:ObjectProperty ;
                         rdfs:domain :ExpertConsultation ;
                         rdfs:range :DigitalServicesCoordinator ;
                         rdfs:comment "The DSC that requested an expert consultation during Art. 40(4) assessment (DA Art. 14)."@en ;
                         rdfs:label "consultation requested by"@en .


###  https://w3id.org/orda#decisionMadeBy
:decisionMadeBy rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf prov:wasAssociatedWith ;
                rdfs:domain :Decision ;
                rdfs:range <https://w3id.org/cerif2/Agent> ;
                rdfs:label "decision made by"@en .


###  https://w3id.org/orda#documentStage
:documentStage rdf:type owl:ObjectProperty ;
               rdfs:domain :ProcessDocument ;
               rdfs:range :DocumentStage ;
               rdfs:comment "Links a document to its controlled DocumentStage individual (procedural status). Link versions with prov:wasRevisionOf; prov:used and :usesDocument connect activities to prior snapshots."@en ;
               rdfs:label "document stage"@en .


###  https://w3id.org/orda#employsMethod
:employsMethod rdf:type owl:ObjectProperty ;
               rdfs:domain :ResearchActivity ;
               rdfs:range :ResearchMethod ;
               rdfs:label "employs method"@en .


###  https://w3id.org/orda#filedWith
:filedWith rdf:type owl:ObjectProperty ;
           rdfs:domain :ComplaintFiling ;
           rdfs:range <https://w3id.org/cerif2/Agent> ;
           rdfs:comment "Links a complaint filing to the European Commission and/or relevant Digital Services Coordinator(s) receiving it under Art. 40(12)."@en ;
           rdfs:label "filed with"@en .


###  https://w3id.org/orda#formulatedBy
:formulatedBy rdf:type owl:ObjectProperty ;
              rdfs:domain :ReasonedRequest ;
              rdfs:range :DigitalServicesCoordinatorOfEstablishment ;
              rdfs:comment "The DSC of establishment that formulated the reasoned request."@en ;
              rdfs:label "formulated by"@en .


###  https://w3id.org/orda#hasAccessModality
:hasAccessModality rdf:type owl:ObjectProperty ;
                   rdfs:domain :ReasonedRequest ;
                   rdfs:range :AccessModality ;
                   rdfs:comment "Access modality determined by DSC-E per DA Art. 9. Values are typically odrl:Offer individuals (typed also as :DeterminedAccessOffer) specifying permissions, targets, and constraints."@en ;
                   rdfs:label "has access modality"@en .


###  https://w3id.org/orda#hasAccessAgreement
:hasAccessAgreement rdf:type owl:ObjectProperty ;
                    rdfs:domain :DataAccessProcess ;
                    rdfs:range odrl:Agreement ;
                    rdfs:comment "Instantiated ODRL Agreement when access is granted (assigner: data provider; assignee: research organisation). Terms should align with the reasoned request's :hasAccessModality offer."@en ;
                    rdfs:label "has access agreement"@en .


###  https://w3id.org/orda#hasPersonName
:hasPersonName rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf <https://w3id.org/cerif2/Person#name> ;
               rdfs:domain :Researcher ;
               rdfs:range <https://w3id.org/cerif2/Person_Name> ;
               rdfs:comment "Structured person name (cerifpn:firstNames, cerifpn:familyNames on the range individual)."@en ;
               rdfs:label "has person name"@en .


###  https://w3id.org/orda#hasContact
:hasContact rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf <https://w3id.org/cerif2/Agent#contacts> ;
           rdfs:domain <https://w3id.org/cerif2/Agent> ;
           rdfs:range <https://w3id.org/cerif2/Contact_Information> ;
           rdfs:comment "Postal, electronic, or other CERIF contact information for an agent."@en ;
           rdfs:label "has contact"@en .


###  https://w3id.org/orda#hasAffiliationStatement
:hasAffiliationStatement rdf:type owl:ObjectProperty ;
                         rdfs:subPropertyOf <https://w3id.org/cerif2/Person#isThePersonIn> ;
                         rdfs:domain :Researcher ;
                         rdfs:comment "CERIF affiliation of a researcher. Link the statement to :ResearchOrganisation via cerifaff:hasInstitution."@en ;
                         rdfs:label "has affiliation statement"@en .


###  https://w3id.org/orda#hasApplication
:hasApplication rdf:type owl:ObjectProperty ;
                rdfs:domain :DataAccessProcess ;
                rdfs:range :DataAccessApplication ;
                rdfs:comment "Links a data access process to an application document (version chain via prov:wasRevisionOf)."@en ;
                rdfs:label "has application"@en .


###  https://w3id.org/orda#hasCommunication
:hasCommunication rdf:type owl:ObjectProperty ;
                  rdfs:range :CommunicationEvent ;
                  rdfs:label "has communication"@en .


###  https://w3id.org/orda#hasContribution
:hasContribution rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf <https://w3id.org/cerif2/Project#hasContribution> ;
                 rdfs:domain :ResearchProject ;
                 rdfs:comment "CERIF project membership or participation. Each contribution is a cerif:Contribution_to_Project with cerifctr:hasTarget pointing at the project and cerifact:hasActor pointing at the participating cerif:Person."@en ;
                 rdfs:label "has contribution"@en .


###  https://w3id.org/orda#hasDataAccessProcess
:hasDataAccessProcess rdf:type owl:ObjectProperty ;
                      rdfs:domain :ResearchProject ;
                      rdfs:range :DataAccessProcess ;
                      rdfs:comment "Links a research project to a procedural data access workflow governed by a specific Art. 40 paragraph."@en ;
                      rdfs:label "has data access process"@en .


###  https://w3id.org/orda#hasDataAccessRequest
:hasDataAccessRequest rdf:type owl:ObjectProperty ;
                      owl:inverseOf :isPartOf ;
                      rdfs:domain :ResearchProject ;
                      rdfs:range :DataAccessRequest ;
                      rdfs:comment "Links a research project to a formal data access request. Inverse of :isPartOf."@en ;
                      rdfs:label "has data access request"@en .


###  https://w3id.org/orda#hasDataCatalogue
:hasDataCatalogue rdf:type owl:ObjectProperty ;
                  rdfs:domain :DataProvider ;
                  rdfs:range :DSADataCatalogue ;
                  rdfs:comment "Platform catalogue per DA Art. 6(4)."@en ;
                  rdfs:label "has data catalogue"@en .


###  https://w3id.org/orda#hasDataManagementPlan
:hasDataManagementPlan rdf:type owl:ObjectProperty ;
                       rdfs:domain :ResearchProject ;
                       rdfs:range :DataManagementPlan ;
                       rdfs:label "has data management plan"@en .


###  https://w3id.org/orda#hasDataProtectionConsultation
:hasDataProtectionConsultation rdf:type owl:ObjectProperty ;
                               rdfs:domain :Art40_4_DataAccessRequest ;
                               rdfs:range :DataProtectionConsultation ;
                               rdfs:comment "Consultation with a national data protection authority or the European Data Protection Board on personal-data aspects of the request."@en ;
                               rdfs:label "has data protection consultation"@en .


###  https://w3id.org/orda#hasDataProvider
:hasDataProvider rdf:type owl:ObjectProperty ;
                 rdfs:domain :ResearchProject ;
                 rdfs:range :DataProvider ;
                 rdfs:comment "Links a research project to the VLOP or VLOSE whose data is requested or whose mitigation measures are assessed."@en ;
                 rdfs:label "has data provider"@en .


###  https://w3id.org/orda#hasDateRange
:hasDateRange rdf:type owl:ObjectProperty ;
              rdfs:domain :ResearchProject ;
              rdfs:range <https://w3id.org/cerif2/Date_Range> ;
              rdfs:comment "Project schedule using CERIF Date_Range (cerifdr:startDate / cerifdr:endDate on the range individual)."@en ;
              rdfs:label "has date range"@en .


###  https://w3id.org/orda#hasDecision
:hasDecision rdf:type owl:ObjectProperty ;
             rdfs:range :Decision ;
             rdfs:comment "Links a process activity or phase to a formal Decision."@en ;
             rdfs:label "has decision"@en .


###  https://w3id.org/orda#hasDistribution
:hasDistribution rdf:type owl:ObjectProperty ;
                 rdfs:domain :DSADataCatalogue ;
                 rdfs:range <http://www.w3.org/ns/dcat#Distribution> ;
                 rdfs:comment "A data asset offered in the catalogue."@en ;
                 rdfs:label "has distribution"@en .


###  https://w3id.org/orda#hasDuration
:hasDuration rdf:type owl:ObjectProperty ;
             rdfs:domain time:Interval ;
             rdfs:range time:Duration ;
             rdfs:label "has duration"@en .


###  https://w3id.org/orda#hasExpertConsultation
:hasExpertConsultation rdf:type owl:ObjectProperty ;
                       rdfs:domain :Art40_4_DataAccessRequest ;
                       rdfs:range :ExpertConsultation ;
                       rdfs:comment "Optional expert consultation during assessment of an Art. 40(4) application (DA Art. 14)."@en ;
                       rdfs:label "has expert consultation"@en .


###  https://w3id.org/orda#hasFormalRequest
:hasFormalRequest rdf:type owl:ObjectProperty ;
                  rdfs:domain :DataAccessProcess ;
                  rdfs:range :DataAccessRequest ;
                  rdfs:comment "Links a data access process to the formal request it realises (typed as :Art40_4_DataAccessRequest or :Art40_12_DataAccessRequest)."@en ;
                  rdfs:label "has formal request"@en .


###  https://w3id.org/orda#hasMethod
:hasMethod rdf:type owl:ObjectProperty ;
           rdfs:domain [ rdf:type owl:Class ;
                         owl:unionOf ( :ResearchActivity
                                       :ResearchProject
                                     )
                       ] ;
           rdfs:range :ResearchMethod ;
           rdfs:label "has method"@en .


###  https://w3id.org/orda#hasOrcidIdentifier
:hasOrcidIdentifier rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf <https://w3id.org/cerif2/Agent#hasIdentifier> ;
                    rdfs:domain :Researcher ;
                    rdfs:range <https://w3id.org/cerif2/ORCID_Identifier> ;
                    rdfs:comment "ORCID iD for a researcher (CERIF Agent identifier)."@en ;
                    rdfs:label "has ORCID identifier"@en .


###  https://w3id.org/orda#hasOutput
:hasOutput rdf:type owl:ObjectProperty ;
           rdfs:domain time:Interval ;
           rdfs:range :ProcessDocument ;
           rdfs:comment "Links a process phase to its document output."@en ;
           rdfs:label "has output"@en .


###  https://w3id.org/orda#hasPhase
:hasPhase rdf:type owl:ObjectProperty ;
          owl:inverseOf :occursInProcess ;
          rdfs:domain :DataAccessProcess ;
          rdfs:range time:Interval ;
          rdfs:comment "Links a data access process to one of its temporal phases."@en ;
          rdfs:label "has phase"@en .


###  https://w3id.org/orda#hasQualityAssessment
:hasQualityAssessment rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf <http://www.w3.org/ns/dqv#hasQualityAnnotation> ;
                      rdfs:domain [ rdf:type owl:Class ;
                                    owl:unionOf ( <http://www.w3.org/ns/dcat#Dataset>
                                                  <http://www.w3.org/ns/dcat#Distribution>
                                                )
                                  ] ;
                      rdfs:range <http://www.w3.org/ns/dqv#QualityAnnotation> ;
                      rdfs:comment "Documents known data quality limitations or assessments for a platform dataset or distribution (DQV). Use dqv:inDimension and dcterms:description on the annotation, or dqv:hasQualityMeasurement for numeric metrics."@en ;
                      rdfs:label "has quality assessment"@en .


###  https://w3id.org/orda#hasResearchActivity
:hasResearchActivity rdf:type owl:ObjectProperty ;
                     rdfs:domain :ResearchProject ;
                     rdfs:range :ResearchActivity ;
                     rdfs:label "has research activity"@en .


###  https://w3id.org/orda#hasResearchOutput
:hasResearchOutput rdf:type owl:ObjectProperty ;
                   owl:inverseOf :isOutputOf ;
                   rdfs:domain :ResearchProject ;
                   rdfs:range :ResearchOutput ;
                   rdfs:comment "Links a project to a CERIF research output (publication, report, or dataset resource) produced using accessed data."@en ;
                   rdfs:label "has research output"@en .


###  https://w3id.org/orda#hasResearchQuestion
:hasResearchQuestion rdf:type owl:ObjectProperty ;
                     rdfs:domain :ResearchProject ;
                     rdfs:range :ResearchQuestion ;
                     rdfs:label "has research question"@en .


###  https://w3id.org/orda#hasReview
:hasReview rdf:type owl:ObjectProperty ;
           rdfs:domain :ResearchMethod ;
           rdfs:range :ExpertConsultation ;
           rdfs:comment "Links a research method to an expert consultation (e.g. :MethodologicalReview) reviewing necessity and proportionality."@en ;
           rdfs:label "has review"@en .


###  https://w3id.org/orda#hasRorIdentifier
:hasRorIdentifier rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf <https://w3id.org/cerif2/Agent#hasIdentifier> ;
                  rdfs:domain :ResearchOrganisation ;
                  rdfs:range <https://w3id.org/cerif2/ROR_Identifier> ;
                  rdfs:comment "ROR identifier for a research organisation (CERIF Agent identifier)."@en ;
                  rdfs:label "has ROR identifier"@en .


###  https://w3id.org/orda#hasStartInstant
:hasStartInstant rdf:type owl:ObjectProperty ;
                 owl:inverseOf :startInstantOf ;
                 rdfs:domain prov:Activity ;
                 rdfs:range time:Instant ;
                 rdfs:comment "Links an activity to the time:Instant at which it starts. Phase triggers use this instant as the interval beginning via :isTriggeredBy."@en ;
                 rdfs:label "has start instant"@en .


###  https://w3id.org/orda#hasSubPhase
:hasSubPhase rdf:type owl:ObjectProperty ;
             rdfs:domain time:Interval ;
             rdfs:range time:Interval ;
             rdfs:label "has sub-phase"@en .


###  https://w3id.org/orda#hasTopic
:hasTopic rdf:type owl:ObjectProperty ;
          rdfs:domain :ResearchProject ;
          rdfs:range :ResearchTopic ;
          rdfs:label "has topic"@en .


###  https://w3id.org/orda#includesResearcher
:includesResearcher rdf:type owl:ObjectProperty ;
                    rdfs:domain :DataAccessRequest ;
                    rdfs:range :Researcher ;
                    rdfs:comment "Additional researchers covered by the same application (DA Art. 10)."@en ;
                    rdfs:label "includes researcher"@en .


###  https://w3id.org/orda#initiallyAssessedBy
:initiallyAssessedBy rdf:type owl:ObjectProperty ;
                     rdfs:domain :Art40_4_DataAccessRequest ;
                     rdfs:range :DigitalServicesCoordinatorOfMemberState ;
                     rdfs:comment "DSC-M initial assessment under Art. 40(9)."@en ;
                     rdfs:label "initially assessed by"@en .


###  https://w3id.org/orda#investigates
:investigates rdf:type owl:ObjectProperty ;
              rdfs:domain :ResearchQuestion ;
              rdfs:range [ rdf:type owl:Class ;
                           owl:unionOf ( :ResearchTopic
                                         :SystemicRiskCategory
                                       )
                         ] ;
              rdfs:label "investigates"@en .


###  https://w3id.org/orda#isOutputOf
:isOutputOf rdf:type owl:ObjectProperty ;
            rdfs:domain :ResearchOutput ;
            rdfs:range :ResearchProject ;
            rdfs:comment "Inverse of :hasResearchOutput."@en ;
            rdfs:label "is output of"@en .


###  https://w3id.org/orda#isPartOf
:isPartOf rdf:type owl:ObjectProperty ;
          rdfs:domain :DataAccessRequest ;
          rdfs:range :ResearchProject ;
          rdfs:comment "Links a data access request to the research project it supports."@en ;
          rdfs:label "is part of"@en .


###  https://w3id.org/orda#isTriggeredBy
:isTriggeredBy rdf:type owl:ObjectProperty ;
               rdfs:domain time:Interval ;
               rdfs:range :TriggerActivity ;
               owl:propertyChainAxiom ( time:hasBeginning
                                        :startInstantOf
                                      ) ;
               rdfs:comment "Links a process phase to the trigger activity that marks its beginning. Inferred when the phase's time:hasBeginning instant is the activity's :hasStartInstant."@en ;
               rdfs:label "is triggered by"@en .


###  https://w3id.org/orda#issuedTo
:issuedTo rdf:type owl:ObjectProperty ;
          rdfs:domain :ReasonedRequest ;
          rdfs:range :DataProvider ;
          rdfs:label "issued to"@en .


###  https://w3id.org/orda#madeBy
:madeBy rdf:type owl:ObjectProperty ;
        rdfs:domain [ rdf:type owl:Class ;
                      owl:unionOf ( :DataAccessApplication
                                    :DataAccessRequest
                                  )
                    ] ;
        rdfs:range :PrincipalResearcher ;
        rdfs:label "made by"@en .


###  https://w3id.org/orda#occursInProcess
:occursInProcess rdf:type owl:ObjectProperty ;
                 rdfs:domain time:Interval ;
                 rdfs:range :DataAccessProcess ;
                 rdfs:comment "Scopes a temporal phase to the data access process it belongs to."@en ;
                 rdfs:label "occurs in process"@en .


###  https://w3id.org/orda#occursWithin
:occursWithin rdf:type owl:ObjectProperty ;
              rdfs:domain prov:Activity ;
              rdfs:range time:Interval ;
              rdfs:comment "Links a process activity or document to the process phase in which it occurs."@en ;
              rdfs:label "occurs within"@en .


###  https://w3id.org/orda#operatedBy
:operatedBy rdf:type owl:ObjectProperty ;
            rdfs:domain :DSADataAccessPortal ;
            rdfs:range :RegulatoryAuthority ;
            rdfs:comment "The public authority operating the central Art. 40(4) data access portal (European Commission under DA Art. 3)."@en ;
            rdfs:label "operated by"@en .


###  https://w3id.org/orda#performedBy
:performedBy rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf prov:wasAssociatedWith ;
             rdfs:domain prov:Activity ;
             rdfs:range <https://w3id.org/cerif2/Agent> ;
             rdfs:comment "Links a process activity to the agent who performed it. Subproperty of prov:wasAssociatedWith."@en ;
             rdfs:label "performed by"@en .


###  https://w3id.org/orda#produces
:produces rdf:type owl:ObjectProperty ;
          rdfs:domain prov:Activity ;
          rdfs:range :ProcessDocument ;
          rdfs:comment "Links a process activity to the :ProcessDocument it produces. Inverse of prov:wasGeneratedBy."@en ;
          rdfs:label "produces"@en .


###  https://w3id.org/orda#publishedIn
:publishedIn rdf:type owl:ObjectProperty ;
             rdfs:domain :ReasonedRequest ;
             rdfs:range :DSADataAccessPortal ;
             rdfs:comment "Overview published per DA Art. 11."@en ;
             rdfs:label "published in"@en .


###  https://w3id.org/orda#referencesDataCatalogue
:referencesDataCatalogue rdf:type owl:ObjectProperty ;
                         rdfs:domain [ rdf:type owl:Class ;
                                       owl:unionOf ( :DataAccessApplication
                                                     :DataAccessRequest
                                                   )
                                     ] ;
                         rdfs:range :DSADataCatalogue ;
                         rdfs:label "references data catalogue"@en .


###  https://w3id.org/orda#requestedFrom
:requestedFrom rdf:type owl:ObjectProperty ;
               rdfs:domain :Art40_12_DataAccessRequest ;
               rdfs:range [ rdf:type owl:Class ;
                            owl:unionOf ( :VeryLargeOnlinePlatform
                                          :VeryLargeOnlineSearchEngine
                                        )
                          ] ;
               rdfs:label "requested from"@en .


###  https://w3id.org/orda#requestsData
:requestsData rdf:type owl:ObjectProperty ;
              rdfs:domain [ rdf:type owl:Class ;
                            owl:unionOf ( :DataAccessApplication
                                          :DataAccessRequest
                                        )
                          ] ;
              rdfs:range <http://www.w3.org/ns/dcat#Distribution> ;
              rdfs:label "requests data"@en .


###  https://w3id.org/orda#resultsIn
:resultsIn rdf:type owl:ObjectProperty ;
           rdfs:domain :Art40_4_DataAccessRequest ;
           rdfs:range :ReasonedRequest ;
           rdfs:label "results in"@en .


###  https://w3id.org/orda#startInstantOf
:startInstantOf rdf:type owl:ObjectProperty ;
                rdfs:domain time:Instant ;
                rdfs:range prov:Activity ;
                rdfs:label "start instant of"@en .


###  https://w3id.org/orda#submittedBy
:submittedBy rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :performedBy ;
             rdfs:domain prov:Activity ;
             rdfs:label "submitted by"@en .


###  https://w3id.org/orda#submittedVia
:submittedVia rdf:type owl:ObjectProperty ;
              rdfs:domain :Art40_4_DataAccessRequest ;
              rdfs:range :DSADataAccessPortal ;
              rdfs:comment "Art. 40(4) applications must use the portal (DA Art. 3). Prefer linking to :DSADataAccessPortalInstance."@en ;
              rdfs:label "submitted via"@en .


###  https://w3id.org/orda#suggestsModality
:suggestsModality rdf:type owl:ObjectProperty ;
                  rdfs:domain [ rdf:type owl:Class ;
                                owl:unionOf ( :DataAccessApplication
                                              :DataAccessRequest
                                            )
                              ] ;
                  rdfs:range :AccessModality ;
                  rdfs:comment "Researcher-proposed access terms at application stage. Range individuals should be typed as :ProposedAccessOffer (odrl:Offer + :AccessModality) with odrl:permission rules targeting requested dcat:Distribution assets."@en ;
                  rdfs:label "suggests modality"@en .


###  https://w3id.org/orda#targets
:targets rdf:type owl:ObjectProperty ;
         rdfs:domain :DataAccessRequest ;
         rdfs:range :DataProvider ;
         rdfs:label "targets"@en .


###  https://w3id.org/orda#usesAccessInterface
:usesAccessInterface rdf:type owl:ObjectProperty ;
                     rdfs:domain :AccessModality ;
                     rdfs:range :AccessInterface ;
                     rdfs:comment "A concrete technical interface (REST API, scraping, bulk download, etc.) realising an access modality."@en ;
                     rdfs:label "uses access interface"@en .


###  https://w3id.org/orda#usesDocument
:usesDocument rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf prov:used ;
              rdfs:domain prov:Activity ;
              rdfs:range :ProcessDocument ;
              rdfs:comment "An activity used a prior :ProcessDocument as input. Subproperty of prov:used."@en ;
              rdfs:label "uses document"@en .


#################################################################
#    Data properties
#################################################################

###  http://www.w3.org/2006/time#inXSDDateTimeStamp
time:inXSDDateTimeStamp rdf:type owl:DatatypeProperty ;
                        rdfs:domain time:Instant ;
                        rdfs:range xsd:dateTimeStamp ;
                        rdfs:comment "The timestamp of a time:Instant, expressed as an XSD dateTimeStamp."@en ;
                        rdfs:label "in XSD dateTimeStamp"@en .


###  http://www.w3.org/ns/csvw#datatype
<http://www.w3.org/ns/csvw#datatype> rdf:type owl:DatatypeProperty ;
                                     rdfs:domain <http://www.w3.org/ns/csvw#Column> ;
                                     rdfs:range xsd:string ;
                                     rdfs:isDefinedBy <http://www.w3.org/ns/csvw#> ;
                                     rdfs:label "datatype"@en .


###  http://www.w3.org/ns/csvw#name
<http://www.w3.org/ns/csvw#name> rdf:type owl:DatatypeProperty ;
                                 rdfs:domain <http://www.w3.org/ns/csvw#Column> ;
                                 rdfs:range xsd:string ;
                                 rdfs:isDefinedBy <http://www.w3.org/ns/csvw#> ;
                                 rdfs:label "name"@en .


###  http://www.w3.org/ns/csvw#required
<http://www.w3.org/ns/csvw#required> rdf:type owl:DatatypeProperty ;
                                     rdfs:domain <http://www.w3.org/ns/csvw#Column> ;
                                     rdfs:range xsd:boolean ;
                                     rdfs:isDefinedBy <http://www.w3.org/ns/csvw#> ;
                                     rdfs:label "required"@en .


###  http://www.w3.org/ns/csvw#titles
<http://www.w3.org/ns/csvw#titles> rdf:type owl:DatatypeProperty ;
                                   rdfs:domain <http://www.w3.org/ns/csvw#Column> ;
                                   rdfs:range xsd:string ;
                                   rdfs:isDefinedBy <http://www.w3.org/ns/csvw#> ;
                                   rdfs:label "titles"@en .


###  https://w3id.org/cerif2/Acknowledgement_Statement#statement
<https://w3id.org/cerif2/Acknowledgement_Statement#statement> rdf:type owl:DatatypeProperty ;
                                                              rdfs:range <https://w3id.org/cerif2/Multilingual_String> ;
                                                              rdfs:isDefinedBy <https://w3id.org/cerif2/> ;
                                                              rdfs:label "statement"@en .


###  https://w3id.org/cerif2/DOI_Identifier#doiId
<https://w3id.org/cerif2/DOI_Identifier#doiId> rdf:type owl:DatatypeProperty ;
                                               rdfs:domain <https://w3id.org/cerif2/DOI_Identifier> ;
                                               rdfs:range <https://w3id.org/cerif2/DOI_ID> ;
                                               rdfs:isDefinedBy <https://w3id.org/cerif2/> ;
                                               rdfs:label "DOI"@en .


###  https://w3id.org/cerif2/Date_Range#endDate
<https://w3id.org/cerif2/Date_Range#endDate> rdf:type owl:DatatypeProperty ;
                                             rdfs:domain <https://w3id.org/cerif2/Date_Range> ;
                                             rdfs:range <https://w3id.org/cerif2/Date> ;
                                             rdfs:isDefinedBy <https://w3id.org/cerif2/> ;
                                             rdfs:label "end date"@en .


###  https://w3id.org/cerif2/Date_Range#startDate
<https://w3id.org/cerif2/Date_Range#startDate> rdf:type owl:DatatypeProperty ;
                                               rdfs:domain <https://w3id.org/cerif2/Date_Range> ;
                                               rdfs:range <https://w3id.org/cerif2/Date> ;
                                               rdfs:isDefinedBy <https://w3id.org/cerif2/> ;
                                               rdfs:label "start date"@en .


###  https://w3id.org/cerif2/Document#title
<https://w3id.org/cerif2/Document#title> rdf:type owl:DatatypeProperty ;
                                         rdfs:domain <https://w3id.org/cerif2/Document> ;
                                         rdfs:range <https://w3id.org/cerif2/Multilingual_String> ;
                                         rdfs:isDefinedBy <https://w3id.org/cerif2/> ;
                                         rdfs:label "title"@en .


###  https://w3id.org/cerif2/Document_Publication#publicationDate
<https://w3id.org/cerif2/Document_Publication#publicationDate> rdf:type owl:DatatypeProperty ;
                                                               rdfs:domain <https://w3id.org/cerif2/Document_Publication> ;
                                                               rdfs:range <https://w3id.org/cerif2/Date> ;
                                                               rdfs:isDefinedBy <https://w3id.org/cerif2/> ;
                                                               rdfs:label "publication date"@en .


###  https://w3id.org/cerif2/ORCID_Identifier#orcidId
<https://w3id.org/cerif2/ORCID_Identifier#orcidId> rdf:type owl:DatatypeProperty ;
                                                   rdfs:domain <https://w3id.org/cerif2/ORCID_Identifier> ;
                                                   rdfs:range <https://w3id.org/cerif2/ORCID_iD> ;
                                                   rdfs:isDefinedBy <https://w3id.org/cerif2/> ;
                                                   rdfs:label "ORCID iD"@en .


###  https://w3id.org/cerif2/Project#name
<https://w3id.org/cerif2/Project#name> rdf:type owl:DatatypeProperty ;
                                       rdfs:domain :ResearchProject ;
                                       rdfs:range <https://w3id.org/cerif2/Multilingual_String> ;
                                       rdfs:isDefinedBy <https://w3id.org/cerif2/> ;
                                       rdfs:label "name"@en .


###  https://w3id.org/cerif2/ROR_Identifier#rorId
<https://w3id.org/cerif2/ROR_Identifier#rorId> rdf:type owl:DatatypeProperty ;
                                               rdfs:domain <https://w3id.org/cerif2/ROR_Identifier> ;
                                               rdfs:range <https://w3id.org/cerif2/ROR_ID> ;
                                               rdfs:isDefinedBy <https://w3id.org/cerif2/> ;
                                               rdfs:label "ROR ID"@en .


###  https://w3id.org/orda#amendmentGrounds
:amendmentGrounds rdf:type owl:DatatypeProperty ;
                  rdfs:domain :AmendmentRequest ;
                  rdfs:range xsd:string ;
                  rdfs:comment "Grounds per Art. 40(5) DSA: (a) no access to data, or (b) significant security vulnerabilities."@en ;
                  rdfs:label "amendment grounds"@en .


###  https://w3id.org/orda#decisionDate
:decisionDate rdf:type owl:DatatypeProperty ;
              rdfs:domain :Decision ;
              rdfs:range xsd:dateTime ;
              rdfs:label "decision date"@en .


###  https://w3id.org/orda#decisionOutcome
:decisionOutcome rdf:type owl:DatatypeProperty ;
                 rdfs:domain :Decision ;
                 rdfs:range xsd:string ;
                 rdfs:comment "The result of a Decision: accepted, rejected, conditional."@en ;
                 rdfs:label "decision outcome"@en .


###  https://w3id.org/orda#hasPublicationCommitment
:hasPublicationCommitment rdf:type owl:DatatypeProperty ;
                          rdfs:domain :DataAccessApplication ;
                          rdfs:range xsd:boolean ;
                          rdfs:comment "Commitment to publish results publicly and free of charge (Art. 40(8)(g) DSA)."@en ;
                          rdfs:label "has publication commitment"@en .


###  https://w3id.org/orda#independenceDeclaration
:independenceDeclaration rdf:type owl:DatatypeProperty ;
                         rdfs:domain :DataAccessApplication ;
                         rdfs:range xsd:string ;
                         rdfs:comment "Declaration of independence from commercial interests (Art. 40(8)(b) DSA)."@en ;
                         rdfs:label "independence declaration"@en .


###  https://w3id.org/orda#maxWorkingDays
:maxWorkingDays rdf:type owl:DatatypeProperty ;
                rdfs:domain time:Interval ;
                rdfs:range xsd:integer ;
                rdfs:comment "Statutory time limit for a process phase, expressed in working days."@en ;
                rdfs:label "maximum working days"@en .


###  https://w3id.org/orda#publicationTimeline
:publicationTimeline rdf:type owl:DatatypeProperty ;
                     rdfs:domain :DataAccessApplication ;
                     rdfs:range xsd:string ;
                     rdfs:comment "Planned timeline for making results publicly available."@en ;
                     rdfs:label "publication timeline"@en .


###  https://w3id.org/orda#requestDate
:requestDate rdf:type owl:DatatypeProperty ;
             rdfs:domain :DataAccessRequest ;
             rdfs:range xsd:date ;
             rdfs:label "request date"@en .


###  https://w3id.org/orda#researcherEmail
:researcherEmail rdf:type owl:DatatypeProperty ,
                               owl:DeprecatedProperty ;
                 rdfs:domain :Researcher ;
                 rdfs:range xsd:string ;
                 rdfs:comment "Deprecated: use cerif:Electronic_Address via :hasContact."@en ;
                 rdfs:label "researcher email"@en .


###  https://w3id.org/orda#researcherName
:researcherName rdf:type owl:DatatypeProperty ,
                              owl:DeprecatedProperty ;
                rdfs:domain :Researcher ;
                rdfs:range xsd:string ;
                rdfs:comment "Deprecated: use cerif:Person_Name via :hasPersonName."@en ;
                rdfs:label "researcher name"@en .


#################################################################
#    Classes
#################################################################

###  http://data.europa.eu/eli/ontology#LegalResource
<http://data.europa.eu/eli/ontology#LegalResource> rdf:type owl:Class ;
                                                   rdfs:comment "A legal resource such as a law, regulation or treaty."@en ;
                                                   rdfs:isDefinedBy <http://data.europa.eu/eli/ontology> ;
                                                   rdfs:label "Legal Resource"@en .


###  http://data.europa.eu/eli/ontology#LegalResourceSubdivision
<http://data.europa.eu/eli/ontology#LegalResourceSubdivision> rdf:type owl:Class ;
                                                              rdfs:subClassOf <http://data.europa.eu/eli/ontology#LegalResource> ;
                                                              rdfs:isDefinedBy <http://data.europa.eu/eli/ontology> ;
                                                              rdfs:label "Legal Resource Subdivision"@en .


###  http://purl.org/dc/terms/MediaTypeOrExtent
dcterms:MediaTypeOrExtent rdf:type owl:Class ;
                          rdfs:isDefinedBy dcterms: ;
                          rdfs:label "Media Type or Extent"@en .


###  http://www.w3.org/2006/time#Duration
time:Duration rdf:type owl:Class .


###  http://www.w3.org/2006/time#Instant
time:Instant rdf:type owl:Class .


###  http://www.w3.org/2006/time#Interval
time:Interval rdf:type owl:Class .


###  http://www.w3.org/ns/csvw#Column
<http://www.w3.org/ns/csvw#Column> rdf:type owl:Class ;
